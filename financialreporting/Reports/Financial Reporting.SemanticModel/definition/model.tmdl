model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	discourageImplicitMeasures
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

queryGroup 'Calculation Tables'

	annotation PBI_QueryGroupOrder = 0

queryGroup 'Fact Tables\SnapShot'

	annotation PBI_QueryGroupOrder = 0

queryGroup 'Fact Tables'

	annotation PBI_QueryGroupOrder = 1

queryGroup 'Fact Tables\Revenue'

	annotation PBI_QueryGroupOrder = 1

queryGroup 'Fact Tables\Production'

	annotation PBI_QueryGroupOrder = 3

queryGroup 'Dim Tables'

	annotation PBI_QueryGroupOrder = 3

queryGroup 'Fact Tables\Expenditure'

	annotation PBI_QueryGroupOrder = 4

queryGroup 'Fact Tables\Customer Margins'

	annotation PBI_QueryGroupOrder = 5

queryGroup 'Fact Tables\EBITDA'

	annotation PBI_QueryGroupOrder = 2

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["Customer Margin","EBITDA","EBITDA Table","HSE","Integrated Margins","Manufacturing Cost","SG&A","Price Index","SnapShot by Product","SnapShot by Site","Revenue Page by Product","Revenue Page by Site","Working Capital","_All Pages","0 - SnapShot","1 - Revenue","2 - EBITDA","3 - Production","4 - Customers","Production by Product","Production by Site","Production by 10K","Dim CAPEX","Sales Channel","Date Table","Dim Hierarchy","Hierachy Bridge","Dim Period Comp","Account","Dim_Period / Set of Books","Switch Table","RP Dim Matrix","ExSlicer","ExSwitch Table","5 - Expenditure","T&D","CAPEX","Expense Hierarchy","EBITDA Accounts","EBITDA Key Stats","EBITDA Comp","Closing_Schedule","Today"]

annotation PBI_ProTooling = ["CalcGroup","DaxQueryView_Desktop","DevMode","TMDLView_Desktop"]

annotation __TEdtr = 1

