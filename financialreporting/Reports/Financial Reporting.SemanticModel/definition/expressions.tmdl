expression 'Expense Hierarchy' =
		let
		    Source = #"Manufacturing Cost",
		    #"Removed Other Columns" = Table.SelectColumns(Source,{"Entity", "Site", "Product1", "Product2"}),
		    #"Renamed Columns" = Table.RenameColumns(#"Removed Other Columns",{{"Product1", "Products"}}),
		    #"Removed Duplicates" = Table.Distinct(#"Renamed Columns", {"Entity"}),
		    #"Uppercased Text" = Table.TransformColumns(#"Removed Duplicates",{{"Products", Text.Upper, type text}}),
		    #"Added Conditional Column" = Table.AddColumn(#"Uppercased Text", "Product Order", each if [Products] = "ECU" then 1 else if [Products] = "VCM" then 2 else if [Products] = "PVC" then 3 else if [Products] = "EDC" then 4 else if [Products] = "F&S" then 5 else if [Products] = "HCL" then 6 else if [Products] = "WATER TREATMENT PRODUCTS" then 7 else if [Products] = "PELS" then 8 else if [Products] = "ETH" then 9 else if [Products] = "POWER" then 10 else if [Products] = "DERIVATIVES" then 11 else if [Products] = "SOLID SPECIALTIES" then 12 else if Text.Contains([Products], "ELIMS") then 13 else null),
		    #"Added Conditional Column1" = Table.AddColumn(#"Added Conditional Column", "Site Order", each if [Site] = "Lake Charles South" then 1 else if [Site] = "Plaquemine" then 2 else if [Site] = "Calvert City" then 3 else if [Site] = "Geismar" then 4 else if [Site] = "Natrium" then 5 else if [Site] = "Lake Charles North" then 6 else if [Site] = "Aberdeen" then 7 else if [Site] = "Beauharnois" then 8 else if [Site] = "Longview-WA" then 9 else null),
		    #"Sorted Rows" = Table.Sort(#"Added Conditional Column1",{{"Product Order", Order.Ascending}}),
		    #"Changed Type" = Table.TransformColumnTypes(#"Sorted Rows",{{"Product Order", Int64.Type}, {"Site Order", Int64.Type}})
		in
		    #"Changed Type"
	lineageTag: c89dbf2e-eed3-4f24-9214-d6d09a7d121f
	queryGroup: 'Dim Tables'

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

