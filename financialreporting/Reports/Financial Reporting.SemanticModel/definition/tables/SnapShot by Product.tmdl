	measure 'Net Revenue Latest Month Actual vs Forecast text' = ```
			
			VAR current_m = 
			CALCULATE(
			    [Net Revenue Actual],
			    ALLSELECTED( 'Date Table' ),
			    ALL( MBR_Columns ),   
			    'Date Table'[Month Offset] = -2 )
			VAR forecast = 
			CALCULATE(
			    [Net Revenue Previous Forecast],
			    ALLSELECTED( 'Date Table' ),
			    ALL( MBR_Columns ),   
			    'Date Table'[Month Offset] = -2 )
			VAR _variance = current_m - forecast
			VAR _percent = DIVIDE( current_m, forecast, BLANK() ) - 1
			VAR NumOfDigits = IFERROR( LEN( CONVERT( INT( abs( _variance ) ), STRING ) ), 0 )
			VAR Commas = REPT(",",
			        SWITCH(
			            TRUE( ),
			            NumOfDigits >= 13,  "4",
			            NumOfDigits >= 10,  "3",
			            NumOfDigits >= 7,   "2",
			            NumOfDigits >= 4,   "1",
			            "0"
			        )
			    )
			VAR Suffix = SWITCH(
			        TRUE( ),
			        NumOfDigits >= 13,  ".000T",
			        NumOfDigits >= 10,  ".00B",
			        NumOfDigits >= 7,   "M",
			        NumOfDigits >= 4,   "K"
			    )
			VAR _Format = "#,0" & Commas & Suffix & ";-#,0" & Commas & Suffix 
			RETURN
			SWITCH(
			    TRUE(),
			    _percent = BLANK(), "N/A",--"Forecast: " & FORMAT( _forecast, _Format) & " " & " | " & "--",
			    _percent >= 0,  /*FORMAT(current_m, _Format ) & " " &*/ UNICHAR(9650) & " +" & FORMAT(ABS(_variance), _Format ) & " (" & FORMAT( _percent, "#,0%") & ")",
			    _percent < 0, /* FORMAT(current_m, _Format ) & " " & */ UNICHAR(9660) & " -" & FORMAT(ABS(_variance), _Format ) & " (" & FORMAT( _percent, "#,0%") & ")"
			)
			```
		isHidden
		displayFolder: 1-Net Revenue
		lineageTag: 88dd2ee4-00c4-4192-9570-46746210421e

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

