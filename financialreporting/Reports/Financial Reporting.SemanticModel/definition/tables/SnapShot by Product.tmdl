	measure 'Volume Produced variance text for card' = ```
			
			VAR _actual = [Volume Produced Actual]
			VAR _budget = [Volume Produced Forecast]
			VAR _variance = _actual - _budget
			VAR _percent = DIVIDE( _actual, _budget, BLANK() )
			VAR NumOfDigits = IFERROR( LEN( CONVERT( INT( _variance ), STRING ) ), 0 )
			VAR Suffix = ".0" &
			    SWITCH(
			        TRUE( ),
			        NumOfDigits >= 13,  "T",
			        NumOfDigits >= 11,  "B",
			        NumOfDigits >= 7,   "M",
			        NumOfDigits >= 4,   "K"
			    )
			VAR Commas = REPT(",",
			        SWITCH(
			            TRUE( ),
			            NumOfDigits >= 13,  "4",
			            NumOfDigits >= 11,  "3",
			            NumOfDigits >= 7,   "2",
			            NumOfDigits >= 4,   "1"
			        )
			    )
			
			VAR _Format = "#,##0" & Commas & Suffix & ";-#,##0" & Commas & Suffix 
			RETURN
			SWITCH(
			    TRUE(),
			    _percent = BLANK(), "Forecast: " & FORMAT( _budget, _Format) & " " & " | " & "--",
			    _percent >= 1,  UNICHAR(9650) & " +" & FORMAT(ABS(_variance), _Format ), -- & " (" & FORMAT( _percent, "#.#%") & ")",
			    _percent < 1, UNICHAR(9660) & " -" & FORMAT(ABS(_variance), _Format ) -- & " (" & FORMAT( _percent, "#.#%") & ")"
			)
			```
		isHidden
		displayFolder: 4-Volume
		lineageTag: 74bc1227-a688-4ea5-af75-2c53c94544ab

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

