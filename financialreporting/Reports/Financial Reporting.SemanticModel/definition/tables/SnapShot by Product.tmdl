	measure 'Net Revenue variance text for card' = ```
			
			VAR _actual = [Net Revenue Actual]
			VAR _budget = [Net Revenue Budget]
			VAR _forecast = [Net Revenue Forecast]
			VAR _varianceBudget = [Net Revenue Actual vs Budget]
			VAR _varianceForecast = [Net Revenue Actual vs Forecast]
			VAR _percent = DIVIDE( _actual, _budget, BLANK() )
			VAR NumOfDigits = IFERROR( LEN( CONVERT( INT( _varianceForecast ), STRING ) ), 0 )
			VAR Suffix = ".0" &
			    SWITCH(
			        TRUE( ),
			        NumOfDigits >= 13,  "T",
			        NumOfDigits >= 10,  "B",
			        NumOfDigits >= 7,   "M",
			        NumOfDigits >= 4,   "K"
			    )
			VAR Commas = REPT(",",
			        SWITCH(
			            TRUE( ),
			            NumOfDigits >= 13,  "4",
			            NumOfDigits >= 10,  "3",
			            NumOfDigits >= 7,   "2",
			            NumOfDigits >= 4,   "1"
			        )
			    )
			
			VAR _Format = "#,##0" & Commas & Suffix & ";-#,##0" & Commas &Suffix 
			RETURN
			SWITCH(
			    TRUE(),
			    _percent = BLANK(), "Forecast: " & FORMAT( _forecast, _Format) & " " & " | " & "--",
			    _percent >= 1,  UNICHAR(9660) & " " & FORMAT(ABS(_varianceForecast), _Format ) & " (+" & FORMAT(ABS(_varianceForecast), _Format ) & " )", --& " (" & FORMAT( _percent, "#.#%") & ")",
			    _percent < 1, UNICHAR(9660) & " " & FORMAT(ABS(_varianceForecast), _Format ) & " (-" & FORMAT(ABS(_varianceForecast), _Format ) & " )" --& " (" & FORMAT( _percent, "#.#%") & ")"
			)
			```
		isHidden
		displayFolder: 1-Net Revenue
		lineageTag: 4ea62931-77c0-487d-8ff8-454f098ca207

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

