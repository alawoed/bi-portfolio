	measure 'EBITDA Forecast variance text for card' = ```
			
			VAR _actual = [EBITDA Actual]
			VAR _forecast = [EBITDA Forecast]
			VAR _variance = _actual - _forecast
			VAR _percent = DIVIDE( _actual, _forecast, BLANK() )
			VAR NumOfDigits = IFERROR( LEN( CONVERT( INT( _variance ), STRING ) ), 0 )
			VAR Suffix = ".0" &
			    SWITCH(
			        TRUE( ),
			        NumOfDigits >= 13,  "T",
			        NumOfDigits >= 10,  "B",
			        NumOfDigits >= 7,   "M",
			        NumOfDigits >= 4,   "K"
			    )
			VAR Commas = REPT(",",
			        SWITCH(
			            TRUE( ),
			            NumOfDigits >= 13,  "4",
			            NumOfDigits >= 10,  "3",
			            NumOfDigits >= 7,   "2",
			            NumOfDigits >= 4,   "1"
			        )
			    )
			
			VAR _Format = "#,##0" & Commas & Suffix & ";-#,##0" & Commas &Suffix 
			RETURN
			SWITCH(
			    TRUE(),
			    _percent = BLANK(), "Budget: " & FORMAT( _forecast, _Format) & " " & " | " & "--",
			    _variance >= 1,  UNICHAR(9650) & " +" & FORMAT(ABS(_variance), _Format ), -- & " (" & FORMAT( _percent, "#.#%") & ")",
			    _variance < 1, UNICHAR(9660) & " -" & FORMAT(ABS(_variance), _Format ) --& " (" & FORMAT( _percent, "#.#%") & ")"
			)
