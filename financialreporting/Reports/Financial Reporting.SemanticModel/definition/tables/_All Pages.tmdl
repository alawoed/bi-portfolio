table '_All Pages'
	lineageTag: 617e2759-9d11-4c67-a51b-be50ca37e333

	measure 'Page Period Card Title' = ```
			
			VAR _monthoffset = FORMAT(CALCULATE( MIN( 'Date Table'[Date] ), 'Date Table'[Month Offset] = -1 ), "yyyy MMM")
			
			VAR _qtdoffset =  
			IF( 
			    MIN( 'Date Table'[Start of Quarter] ) = DATE( YEAR( TODAY() ), MONTH( TODAY() ), 1 ),
			    CALCULATE( MIN( 'Date Table'[Year-QQ] ), 'Date Table'[Quarter Offset] = -1 ),
			    CALCULATE( MIN( 'Date Table'[Year-QQ] ), 'Date Table'[Quarter Offset] = 0 )
			)
			
			VAR _ytdoffset = FORMAT(CALCULATE( MIN( 'Date Table'[Date] ), 'Date Table'[Year Offset] = 0 ), "yyyy MMM") & " - " & FORMAT(CALCULATE( MAX( 'Date Table'[Date] ), 'Date Table'[Month Offset] = -1 ), "yyyy MMM")
			
			VAR _fyroffset = FORMAT(CALCULATE( MIN( 'Date Table'[Date] ), 'Date Table'[Year Offset] = 0 ), "yyyy MMM") & " - " & FORMAT(CALCULATE( MAX( 'Date Table'[Date] ), 'Date Table'[Year Offset] = 0 ), "yyyy MMM")
			
			VAR _final = FORMAT(MIN('SnapShot by Product'[Date]), "yyyy MMM") & " - " & FORMAT(MAX ( 'SnapShot by Product'[Date] ), "yyyy MMM")
			
			VAR __offset_1 = SWITCH(SELECTEDVALUE('Dim Period Comp'[Order]), 0, _monthoffset, 1, _qtdoffset, 2,_ytdoffset, 3,_fyroffset, "")
			
			RETURN 
			
			__offset_1
			```
		lineageTag: 273591de-4b6b-4f27-8e98-1f1b5df5c164

	measure '_Period Comp Name' = ```
			
			VAR _qtdoffset = "vs " &  IF( 
			    MIN( 'Date Table'[Start of Quarter] ) = DATE( YEAR( TODAY() ), MONTH( TODAY() ), 1 ),
			    CALCULATE( MIN( 'Date Table'[Year-QQ] ), 'Date Table'[Quarter Offset] = -2),
			    CALCULATE( MIN( 'Date Table'[Year-QQ] ), 'Date Table'[Quarter Offset] = -1)
			)
			
			VAR _ytdoffset = " vs YTD "& CALCULATE( MIN( 'Date Table'[Year] ), 'Date Table'[Year Offset] = -1 ) 
			
			VAR __offset_1 = 
			                SWITCH(SELECTEDVALUE('Dim Period Comp'[Order]), 
			                0, "vs Forecast",
			                1, _qtdoffset, 
			                2, _ytdoffset,
			                3, "vs Prev Forecast",
			                "")
			
			RETURN 
			
			__offset_1
			```
		lineageTag: e5cc16ce-1e6e-40d6-bfb0-b8333b0a9497

	measure '_DD Preiod Comp Name' = ```
			
			VAR _monthoffset =  FORMAT(CALCULATE( MIN( 'Date Table'[Date] ), 'Date Table'[Month Offset] = -1 ), "yyyy MMM") 
			                    & " vs " & 
			                    FORMAT(CALCULATE( MIN( 'Date Table'[Date] ), 'Date Table'[Month Offset] = -2 ), "yyyy MMM") 
			
			VAR _qtdoffset =   IF( 
			                MIN( 'Date Table'[Start of Quarter] ) = DATE( YEAR( TODAY() ), MONTH( TODAY() ), 1 ),
			                CALCULATE( MIN( 'Date Table'[Year-QQ] ), 'Date Table'[Quarter Offset] = -1 ) 
			                & " vs " & 
			                CALCULATE( MIN( 'Date Table'[Year-QQ] ), 'Date Table'[Quarter Offset] = -5 ),
			                CALCULATE( MIN( 'Date Table'[Year-QQ] ), 'Date Table'[Quarter Offset] = 0 ) 
			                & " vs " & 
			                CALCULATE( MIN( 'Date Table'[Year-QQ] ), 'Date Table'[Quarter Offset] = -4 ) )
			        
			VAR _ytdoffset =    "YTD "& CALCULATE( MIN( 'Date Table'[Year] ), 'Date Table'[Year Offset] = 0 ) 
			                    & " vs " & 
			                    "YTD "& CALCULATE( MIN( 'Date Table'[Year] ), 'Date Table'[Year Offset] = 0 )
			
			VAR _fyroffset =     "FY "& FORMAT(CALCULATE( MIN( 'Date Table'[Date] ), 'Date Table'[Year Offset] = 0 ), "yyyy") 
			                    & " vs " & 
			                     "FY "& FORMAT(CALCULATE( MAX( 'Date Table'[Date] ), 'Date Table'[Year Offset] = -1 ), "yyyy")
			
			VAR _final =        ""
			
			VAR __offset_1 = 
			                SWITCH(
			                    SELECTEDVALUE('Dim Period Comp'[Order]), 
			                    0, _monthoffset, 
			                    1, _qtdoffset, 
			                    2,_ytdoffset, 
			                    3,_fyroffset, 
			                    _final)
			
			RETURN 
			
			__offset_1
			```
		lineageTag: c9e0594b-1607-487c-beff-80466e23ca1e

	measure '_DD2 Period N' = ```
			
			
