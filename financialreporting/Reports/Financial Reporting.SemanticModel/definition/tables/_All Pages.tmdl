	measure 'Dynamic label' = [Net Revenue Actual]
		displayFolder: Formating
		lineageTag: 63529d2c-6f3f-488b-9db0-8b29853643ba

		formatStringDefinition =
				SWITCH(
				    TRUE(),
				        abs([Dynamic label]) < 1000, "0",         -- Units
				        abs([Dynamic label]) < 1000000,"#, K",    -- Thousand
				        abs([Dynamic label]) < 1000000000, "#,, M",   -- Million
				        abs([Dynamic label]) < 1000000000000, "#,,,.00 B" ,  -- Billion
				        abs([Dynamic label]) >= 1000000000000, "#,,,,.000 T"   -- Trillion
				)

		changedProperty = DisplayFolder

		changedProperty = Name

