	measure CheckNegative =
			
			VAR lastDatewData = MAXX(
			    FILTER(
			        'Date Table',
			        NOT(ISBLANK([Value_by_Product_Actual]))
			    ),
			    'Date Table'[Date])
			
			VAR perchange = CALCULATE(
			    [PerChange],
			    FILTER(
			        'Date Table',
			        'Date Table'[Date] = lastDatewData ))
			
			RETURN
			
			IF(perchange > 1, 0, 1)
