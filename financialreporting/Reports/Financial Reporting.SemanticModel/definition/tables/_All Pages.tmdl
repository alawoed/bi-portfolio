	measure 'VPA Variance' = ```
			
			
			VAR currentm = CALCULATE(
			    [Value_by_Product_Site_Actual],
			    DATESMTD('Date Table'[Date]))
			
			VAR prevm = CALCULATE(
			    [Value_by_Product_Site_Actual],
			    PREVIOUSMONTH('Date Table'[Date]))
			
			VAR perChange = ROUNDUP(
			    IF(
			        NOT(ISBLANK(prevm)),
			        (currentm - prevm) / prevm,
			        0
			    ) * 100, 0)
			
			VAR bridge = CEILING(currentm - prevm, 1)
			
			VAR VPAvariance = IF(perChange > 0 && bridge < 0, bridge * -1, bridge)
			
			VAR formattedVPAvariance = 
			    SWITCH(
			        TRUE(),
			        ABS(VPAvariance) >= 1e9, 
			            IF(perChange > 0, "+" & FORMAT(VPAvariance / 1e9, "0") & "B", FORMAT(VPAvariance / 1e9, "0") & "B"),
			        ABS(VPAvariance) >= 1e6, 
			            IF(perChange > 0, "+" & FORMAT(VPAvariance / 1e6, "0") & "M", FORMAT(VPAvariance / 1e6, "0") & "M"),
			        ABS(VPAvariance) >= 1e3, 
			            IF(perChange > 0, "+" & FORMAT(VPAvariance / 1e3, "0") & "K", FORMAT(VPAvariance / 1e3, "0") & "K"),
			        IF(perChange > 0, "+" & FORMAT(VPAvariance, "0"), FORMAT(VPAvariance, "0")))
			        
			VAR icon = IF(perChange > 0 , "▲ ", "▼ " )
			
			RETURN 
			    icon  & formattedVPAvariance & " (" & perChange & "%" & ")"
			```
		displayFolder: Formating
		lineageTag: 5c8a8734-5c5e-4299-909c-4b43b57de9ca

		annotation PBI_FormatHint = {"isGeneralNumber":true}

