	measure 'Color Formatting Month Progression' = ```
			
			VAR _rev_current = 
			CALCULATE(
			    [Net Revenue Actual],
			    ALLSELECTED( 'Date Table' ),
			    ALL( MBR_Columns ),   
			    'Date Table'[Month Offset] = -2 )
			VAR _rev_prev = 
			CALCULATE(
			    [Net Revenue Actual],
			    ALLSELECTED( 'Date Table' ),
			    ALL( MBR_Columns ),   
			    'Date Table'[Month Offset] = -3 )
			
			VAR _ebit_current = 
			CALCULATE(
			    [EBITDA Actual],
			    ALLSELECTED( 'Date Table' ),
			    ALL( MBR_Columns ),   
			    'Date Table'[Month Offset] = -2 )
			VAR _ebit_prev = 
			CALCULATE(
			    [EBITDA Actual],
			    ALLSELECTED( 'Date Table' ),
			    ALL( MBR_Columns ),   
			    'Date Table'[Month Offset] = -3 )
			
			VAR _cash_current = 
			CALCULATE(
			    [Cash Flows Actual],
			    ALLSELECTED( 'Date Table' ),
			    ALL( MBR_Columns ),   
			    'Date Table'[Month Offset] = -2 )
			VAR _cash_prev = 
			CALCULATE(
			    [Cash Flows Actual],
			    ALLSELECTED( 'Date Table' ),
			    ALL( MBR_Columns ),   
			    'Date Table'[Month Offset] = -3 )
			
			VAR _vol_current = 
			CALCULATE(
			    [Volume Produced Actual],
			    ALLSELECTED( 'Date Table' ),
			    ALL( MBR_Columns ),   
			    'Date Table'[Month Offset] = -2 )
			VAR _vol_prev = 
			CALCULATE(
			    [Volume Produced Actual],
			    ALLSELECTED( 'Date Table' ),
			    ALL( MBR_Columns ),   
			    'Date Table'[Month Offset] = -3 )
			    
			RETURN 
			SWITCH(
			    TRUE(),
			    MIN( 'SnapShot by Product'[ACCOUNT] ) = "NET_REVENUE", _rev_current - _rev_prev,
			    MIN( 'SnapShot by Product'[ACCOUNT] ) = "EBITDA", _ebit_current - _ebit_prev,
			    MIN( 'SnapShot by Product'[ACCOUNT] ) = "910000", _vol_current - _vol_prev,
			    MIN( 'SnapShot by Product'[ACCOUNT] ) = "Cash flows", _cash_current - _cash_prev
			    )
			
			--IF( _variance >= 0, "Green", "Red" )
			```
		formatString: 0
		displayFolder: Formating
		lineageTag: 8cf8a07f-ff44-4533-b168-add1b1c47ca2

