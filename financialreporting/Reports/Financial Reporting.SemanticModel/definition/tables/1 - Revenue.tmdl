table '1 - Revenue'
	lineageTag: 3447a94f-e2ba-4995-83d3-adfe8df91619

	measure RP_Value_by_Product_Site = ```
			
			VAR _orgvalprd = SUM('Revenue Page by Product'[Value_O])/1000000
			VAR _newvalprd = SUM('Revenue Page by Product'[Value])
			
			VAR _product = SWITCH([PP Hier SBU Filter], 0 , _orgvalprd , 1 , _newvalprd)
			
			
			RETURN 
			IF(
			    SELECTEDVALUE('Switch Table'[Order]) = 1 , 
			    _product )
			```
		displayFolder: 0-Base Measures
		lineageTag: f3b1b029-222c-45c4-b986-1de87e999772

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure RP_Value_by_Product_Site_Actual = ```
			
			
			VAR _site       = CALCULATE(
			                            [RP_Value_by_Product_Site] , 
			                            'Revenue Page by Site'[CATEGORY] IN {"FORECAST"} &&
			                            'Revenue Page by Site'[Period / Set of Books] = "Actual / Current Forecast" &&
			                            'Revenue Page by Site'[Date] <= DATE( YEAR(MIN('Today'[Today])), MONTH(MIN('Today'[Today]))-1, 01))
			VAR _product    = CALCULATE(
			                            [RP_Value_by_Product_Site] , 
			                            'Revenue Page by Product'[CATEGORY] IN {"FORECAST"} &&
			                            'Revenue Page by Product'[Period / Set of Books] = "Actual / Current Forecast" &&
			                            'Revenue Page by Product'[Date] <= DATE( YEAR(MIN('Today'[Today])), MONTH(MIN('Today'[Today]))-1, 01))
			
			
			RETURN 
			IF(
			    SELECTEDVALUE('Switch Table'[Order]) = 0 , 
			    _site, 
			    _product )
			```
		displayFolder: 0-Base Measures
		lineageTag: 93533b83-8336-4e3d-9fdd-7678b349c358

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure RP_Value_by_Product_Site_Budget = ```
			
			VAR _product = SUMX(
			    FILTER(
			        'Revenue Page by Product', 
			        'Revenue Page by Product'[Period / Set of Books] = "Budget"
			    ),   
			    [RP_Value_by_Product_Site] 
			)
			
			VAR _site = SUMX(
			    FILTER(
			        'Revenue Page by Site', 
			        'Revenue Page by Site'[Period / Set of Books] = "Budget"
			    ),   
			    [RP_Value_by_Product_Site] 
			)
			
			RETURN 
			IF(
			    SELECTEDVALUE('Switch Table'[Order]) = 0 , 
			    _site, 
			    _product )
			```
		displayFolder: 0-Base Measures
		lineageTag: bffa5df4-88d4-4052-81d6-f6f8f26d8862

