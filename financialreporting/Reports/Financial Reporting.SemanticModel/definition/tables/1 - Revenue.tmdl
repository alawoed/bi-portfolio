	measure 'RP Net Revenue Variance Forecast Format' = ```
			
			
			-- Month-over-month comparison
			VAR _monthrevA = CALCULATE([RP Net Revenue Prev Forecast], 'Date Table'[Month Offset] = -1)
			VAR _monthrevB = CALCULATE([RP Net Revenue Actual], 'Date Table'[Month Offset] = -1)
			VAR _monthvar = _monthrevB - COALESCE(_monthrevA, 0)
			VAR _monthvarper = DIVIDE(_monthvar, ABS(_monthrevA))
			
			-- Quarter-over-quarter comparison
			VAR _qtdrevA = IF( 
			    MIN( 'Date Table'[Start of Quarter] ) = DATE( YEAR( TODAY() ), MONTH( TODAY() ), 1 ),
			    CALCULATE( [RP Net Revenue Actual], 'Date Table'[Quarter Offset] = -2 ),
			    CALCULATE( [RP Net Revenue Actual], 'Date Table'[Quarter Offset] = -1 ) )
			VAR _qtdrevB = IF( 
			    MIN( 'Date Table'[Start of Quarter] ) = DATE( YEAR( TODAY() ), MONTH( TODAY() ), 1 ),
			    CALCULATE( [RP Net Revenue Actual + Forecast], 'Date Table'[Quarter Offset] = -1 ),
			    CALCULATE( [RP Net Revenue Actual + Forecast], 'Date Table'[Quarter Offset] = 0 ) )
			VAR _qtdvar = _qtdrevB - COALESCE(_qtdrevA, 0)
			VAR _qtdvarper = DIVIDE(_qtdvar, ABS(_qtdrevA))
			
			-- Year-over-year comparison
			VAR _ytdrevA = CALCULATE([RP Net Revenue Actual], 'Date Table'[Year Offset] = -1 && 'Date Table'[Month Offset] < -12 )
			VAR _ytdrevB = CALCULATE([RP Net Revenue Actual], 'Date Table'[Year Offset] = 0 && 'Date Table'[Month Offset] < 0 )
			VAR _ytdvar = _ytdrevB - COALESCE(_ytdrevA, 0 )
			VAR _ytdvarper = DIVIDE(_ytdvar, ABS(_ytdrevA))
			
			-- Full-year forecast comparison
			VAR _fyrrevA = CALCULATE([RP Net Revenue Prev Forecast], 'Date Table'[Year Offset] = 0) 
			VAR _fyrrevB = CALCULATE([RP Net Revenue Actual + Forecast], 'Date Table'[Year Offset] = 0)
			VAR _fyrvar = _fyrrevB - COALESCE(_fyrrevA,0)
			VAR _fyrvarper = DIVIDE(_fyrvar, ABS(_fyrrevA))
			
			
			
			-- Final output based on selected comparison type
			VAR _final = BLANK()
			
			VAR finalvarper = 
			    SWITCH(
			        SELECTEDVALUE('Dim Period Comp'[Order]),
			        0, _monthvar,
			        1, _qtdvar,
			        2, _ytdvar,
			        3, _fyrvar,
			        BLANK()
			    )
			
			VAR _varfinal = SWITCH(
			    TRUE(),
			    finalvarper = BLANK(), "Red",
			    finalvarper > 0, "Green",
			    finalvarper <= 0, "Red")
			
			RETURN
			_varfinal
			```
