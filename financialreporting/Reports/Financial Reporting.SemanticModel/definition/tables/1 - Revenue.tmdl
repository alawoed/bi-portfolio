	measure 'RP Net Revenue Variance Budget Format' = ```
			
			
			-- Month-over-month comparison
			VAR _monthrevA = CALCULATE([RP Net Revenue Budget], 'Date Table'[Month Offset] = -1)
			VAR _monthrevB = CALCULATE([RP Net Revenue Actual], 'Date Table'[Month Offset] = -1)
			VAR _monthvar = _monthrevB - _monthrevA
			VAR _monthvarper = DIVIDE(_monthvar, ABS(_monthrevA))
			
			-- Quarter-over-quarter comparison
			VAR _qtdrevA = CALCULATE([RP Net Revenue Budget], 'Date Table'[Quarter Offset] = -1)
			VAR _qtdrevB = CALCULATE([RP Net Revenue Actual], 'Date Table'[Quarter Offset] = -1)
			VAR _qtdvar = _qtdrevB - _qtdrevA
			VAR _qtdvarper = DIVIDE(_qtdvar, ABS(_qtdrevA))
			
			-- Year-over-year comparison
			VAR _ytdrevA = CALCULATE([RP Net Revenue Budget], 'Date Table'[Year Offset] = 0 && 'Date Table'[Month Offset] <= 0)
			VAR _ytdrevB = CALCULATE([RP Net Revenue Actual], 'Date Table'[Year Offset] = 0 && 'Date Table'[Month Offset] <= 0)
			VAR _ytdvar = _ytdrevB - _ytdrevA
			VAR _ytdvarper = DIVIDE(_ytdvar, ABS(_ytdrevA))
			
			-- Full-year forecast comparison
			VAR _fyrrevA = CALCULATE([RP Net Revenue Budget], 'Date Table'[Year Offset] = 0) 
			VAR _fyrrevB = CALCULATE([RP Net Revenue Actual + Forecast], 'Date Table'[Year Offset] = 0)
			VAR _fyrvar = _fyrrevB - _fyrrevA
			VAR _fyrvarper = DIVIDE(_fyrvar, ABS(_fyrrevA))
			
			
			-- Final output based on selected comparison type
			VAR _final = BLANK()
			
			VAR finalvarper = 
			    SWITCH(
			        SELECTEDVALUE('Dim Period Comp'[Order]),
			        0, _monthvar,
			        1, _qtdvar,
			--        2, _ytdvar,
			        3, _fyrvar,
			         BLANK()
			    )
			
			VAR _varfinal = SWITCH(
			    TRUE(),
			    ISBLANK(finalvarper), "White",
			    finalvarper <= 0, "Red",
			    finalvarper > 0, "Green")
			
			RETURN
			_varfinal
			
			```
		displayFolder: 1-Net Revenue
		lineageTag: 1a645c49-b8cb-4f8b-9aee-c13c20b33361

	measure 'RP Net Revenue Variance Prevs Period Format' = ```
			
			-- Month-over-month comparison
			VAR _monthrevA = CALCULATE([RP Net Revenue Actual], 'Date Table'[Month Offset] = -2)
			VAR _monthrevB = CALCULATE([RP Net Revenue Actual], 'Date Table'[Month Offset] = -1)
			VAR _monthvar = _monthrevB - _monthrevA
			VAR _monthvarper = DIVIDE(_monthvar, ABS(_monthrevA))
			
			-- Quarter-over-quarter comparison
			VAR _qtdrevA = CALCULATE([RP Net Revenue Actual], 'Date Table'[Quarter Offset] = -1)
			VAR _qtdrevB = CALCULATE([RP Net Revenue Actual], 'Date Table'[Quarter Offset] = 0)
			VAR _qtdvar = _qtdrevB - _qtdrevA
			VAR _qtdvarper = DIVIDE(_qtdvar, ABS(_qtdrevA))
			
			-- Year-over-year comparison
			VAR _ytdrevA = CALCULATE([RP Net Revenue Actual], 'Date Table'[Year Offset] = -1 && 'Date Table'[Month Offset] <= -13)
			VAR _ytdrevB = CALCULATE([RP Net Revenue Actual], 'Date Table'[Year Offset] = 0 && 'Date Table'[Month Offset] <= 0)
			VAR _ytdvar = _ytdrevB - _ytdrevA
			VAR _ytdvarper = DIVIDE(_ytdvar, ABS(_ytdrevA))
			
			-- Full-year forecast comparison
			VAR _fyrrevA = CALCULATE([RP Net Revenue Actual + Forecast], 'Date Table'[Year Offset] = -1) 
			VAR _fyrrevB = CALCULATE([RP Net Revenue Actual + Forecast], 'Date Table'[Year Offset] = 0)
			VAR _fyrvar = _fyrrevB - _fyrrevA
			VAR _fyrvarper = DIVIDE(_fyrvar, ABS(_fyrrevA))
			
			
			-- Final output based on selected comparison type
			VAR _final = BLANK()
			
			VAR finalvarper = 
			    SWITCH(
			        SELECTEDVALUE('Dim Period Comp'[Order]),
			        0, _monthvar,
			        1, _qtdvar,
			        2, _ytdvar,
			        3, _fyrvar
			    )
			
			VAR _varfinal = SWITCH(
			    TRUE(),
			    ISBLANK(finalvarper), "White",
			    finalvarper <= 0, "Red",
			    finalvarper > 0, "Green")
			
			RETURN
			_varfinal
			
			```
		displayFolder: 1-Net Revenue
		lineageTag: b5f7479d-4edb-40f6-8195-df3798127524

		annotation PBI_FormatHint = {"isGeneralNumber":true}

