	measure 'RP Net Revenue Latest Period' = ```
			
			VAR _monthoffset = CALCULATE(
			        [RP Net Revenue Actual],
			        'Date Table'[Year Offset] = 0 && 'Date Table'[Month Offset] = -1)
			
			VAR _qtdoffset = CALCULATE(
			        [RP Net Revenue Actual + Forecast],
			        'Date Table'[Quarter Offset] = 0)
			        
			VAR _ytdoffset = CALCULATE(
			        [RP Net Revenue Actual],
			        'Date Table'[Year Offset] = 0 && 'Date Table'[Month Offset] <= -1)
			
			VAR _fyroffset = CALCULATE(
			        [RP Net Revenue Actual + Forecast],
			        'Date Table'[Year Offset] = 0)
			
			VAR __offset_1 = SWITCH(SELECTEDVALUE('Dim Period Comp'[Order]), 0, _monthoffset, 1, _qtdoffset, 2,_ytdoffset, 3,_fyroffset, [RP Net Revenue Actual])
			
			VAR formart_variance = 
			    SWITCH(
			        TRUE(),
			        ABS(__offset_1) >= 1000000, FORMAT(__offset_1 / 1000000, "$#,0") & "M",
			        ABS(__offset_1) >= 1000, FORMAT(__offset_1 / 1000, "$#,0") & "K",
			        FORMAT(__offset_1, "#,0")
			    )
			
			RETURN 
			SWITCH(
			    SELECTEDVALUE('Dim Period Comp'[Period]),
			    "All Time", "",
			    formart_variance
			)
			```
		displayFolder: 1-Net Revenue
		lineageTag: 49aac545-1562-4ea2-a7a1-2015d7e8b7cd

