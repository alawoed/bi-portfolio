		displayFolder: 3-Price
		lineageTag: 69382ba4-4e81-4ee2-9c37-1f27998d9cd7

	measure 'RP Average Price per Unit Prev Forecast' =
			
			100*DIVIDE(
			    [RP Net Revenue Prev Forecast]/1000000,
			    [RP Sales Volume Prev Forecast],
			    BLANK()
			)
		displayFolder: 3-Price
		lineageTag: c257d85b-f594-430d-9130-20ba28b1c37f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'RP CY Prev Forecast Price' =
			
			VAR _monthoffset = CALCULATE([RP Average Price per Unit Prev Forecast], 'Date Table'[Year Offset] = 0 && 'Date Table'[Month Offset] <= -1)
			VAR _qtdoffset = CALCULATE([RP Average Price per Unit Prev Forecast], 'Date Table'[Year Offset] = 0)
			VAR _ytdoffset = CALCULATE([RP Average Price per Unit Prev Forecast], 'Date Table'[Year Offset] = 0 && 'Date Table'[Month Offset] < 0)
			VAR _fyroffset = CALCULATE([RP Average Price per Unit Prev Forecast], 'Date Table'[Year Offset] = 0)
			VAR _alltime = CALCULATE([RP Average Price per Unit Prev Forecast], 'Date Table'[Year Offset] = 0)
			
			
			VAR __offset_1 = SWITCH(SELECTEDVALUE('Dim Period Comp'[Order]), 0, _monthoffset, 1, _monthoffset, 2,_ytdoffset, 3,_fyroffset, 4, BLANK())
			
			RETURN
			   __offset_1
