	measure 'RP Average Price per Unit Actual + Forecast' = [RP Average Price per Unit Actual] + [RP Average Price per Unit Forecast]
		displayFolder: 3-Price
		lineageTag: bc2dbe0a-209a-423f-8140-a8bdc4555f6f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Price Variance' = ```
			
			VAR _c4 = [RP CY NR Actual Matrix]
			VAR _d4 = [RP CY SV Actual Matrix]
			VAR _g4 = SWITCH(SELECTEDVALUE('RP Rev Matrix'[Parameter Order]), 0 , [RP CY Budget Matrix], 1 , [RP CY Prev Forecast Matrix], 2 , [RP PY NR Actual])
			VAR _h4 = SWITCH(SELECTEDVALUE('RP Rev Matrix'[Parameter Order]), 0 , [RP CY SV Budget Matrix], 1 , [RP CY SV Prev Forecast Matrix], 2 , [RP PY SV Actual Chart])
			
			VAR _e4 =  (_C4/_D4) *100
			VAR _i4 =  (_G4/_H4) *100
			VAR _o4 = _e4 -_i4
			VAR _p4 = _d4 - _h4
			
			VAR _k4 = (_O4/100) * _D4
			VAR _l4 = _P4*(_I4/100)
			
			RETURN 
			_k4
			```
		formatString: #,##0.0
		displayFolder: 4-Variance
		lineageTag: 8a83bdd1-dceb-41e9-9936-8e604be3f5df

		annotation PBI_FormatHint = {"isCustom":true}

	measure 'Volume Variance' = ```
			
			VAR _c4 = [RP CY NR Actual Matrix]
			VAR _d4 = [RP CY SV Actual Matrix]
			VAR _g4 = SWITCH(SELECTEDVALUE('RP Rev Matrix'[Parameter Order]), 0 , [RP CY Budget Matrix], 1 , [RP CY Prev Forecast Matrix], 2 , [RP PY NR Actual])
			VAR _h4 = SWITCH(SELECTEDVALUE('RP Rev Matrix'[Parameter Order]), 0 , [RP CY SV Budget Matrix], 1 , [RP CY SV Prev Forecast Matrix], 2 , [RP PY SV Actual Chart])
			
			VAR _e4 =  (_C4/_D4) *100
			VAR _i4 =  (_G4/_H4) *100
			VAR _o4 = _e4 -_i4
			VAR _p4 = _d4 - _h4
			
			VAR _k4 = (_O4/100) * _D4
			VAR _l4 = _P4*(_I4/100)
			
			RETURN 
			_l4
			```
		formatString: 0.0
		displayFolder: 4-Variance
		lineageTag: a74ecf57-e69b-41ae-951f-d7f8e7ab5a9c

	measure 'Total Variance' = ```
			
			VAR _c4 = [RP CY NR Actual Matrix]
			VAR _d4 = [RP CY SV Actual Matrix]
			VAR _g4 = SWITCH(SELECTEDVALUE('RP Rev Matrix'[Parameter Order]), 0 , [RP CY Budget Matrix], 1 , [RP CY Prev Forecast Matrix], 2 , [RP PY NR Actual])
			VAR _h4 = SWITCH(SELECTEDVALUE('RP Rev Matrix'[Parameter Order]), 0 , [RP CY SV Budget Matrix], 1 , [RP CY SV Prev Forecast Matrix], 2 , [RP PY SV Actual Chart])
			
			VAR _tv = _c4 - _g4
			
			RETURN 
			_tv
			```
		formatString: #,##0.0
