	measure 'RP CY Price' = ```
			
			VAR _monthoffset = CALCULATE([RP Average Price per Unit Actual], 'Date Table'[Year Offset] = 0)
			VAR _qtdoffset = CALCULATE([RP Average Price per Unit Actual], 'Date Table'[Year Offset] = 0 && 'Date Table'[Quarter Offset] <= -1)
			VAR _ytdoffset = CALCULATE([RP Average Price per Unit Actual], 'Date Table'[Year Offset] = 0 && 'Date Table'[Month Offset] <= -1)
			VAR _fyroffset = CALCULATE([RP Average Price per Unit Actual], 'Date Table'[Year Offset] = 0)
			VAR _alltime = BLANK()
			
			
			VAR __offset_1 = SWITCH(SELECTEDVALUE('Dim Period Comp'[Order]), 0, _monthoffset, 1, _qtdoffset, 2,_ytdoffset, 3,_fyroffset, _alltime)
			
			RETURN 
			    __offset_1
			```
		formatString: 0.0
		displayFolder: 3-Price
		lineageTag: 98ff1b2e-bbe9-468d-b69f-6e06c96305eb

	measure 'RP CY Forecast Price' =
			
			VAR _monthoffset = CALCULATE([RP Average Price per Unit Forecast], 'Date Table'[Year Offset] = 0)
			VAR _qtdoffset = CALCULATE([RP Average Price per Unit Actual + Forecast], 'Date Table'[Year Offset] = 0 && 'Date Table'[Quarter Offset]>= 0)
			VAR _ytdoffset = BLANK()
			VAR _fyroffset = _monthoffset
			VAR _alltime = CALCULATE([RP Average Price per Unit Actual + Forecast], 'Date Table'[Year Offset] >= 0)
			
			
			VAR __offset_1 = SWITCH(SELECTEDVALUE('Dim Period Comp'[Order]), 0, _monthoffset, 1, _qtdoffset, 2,_monthoffset, 3,_fyroffset, _alltime)
			
			RETURN
			   __offset_1
		formatString: 0.0
		displayFolder: 3-Price
		lineageTag: 0212ba24-9488-4323-afc1-20c43dcd5ea6

	measure 'RP PY Price' = ```
			
			VAR _monthoffset = CALCULATE([RP Average Price per Unit Actual], 'Date Table'[Year Offset] = -1 )
			VAR _qtdoffset = CALCULATE([RP Average Price per Unit Actual], 'Date Table'[Year Offset] = -1 && 'Date Table'[Quarter Offset] < 4)
			VAR _ytdoffset = CALCULATE([RP Average Price per Unit Actual], 'Date Table'[Year Offset] = -1 )
			VAR _fyroffset = CALCULATE([RP Average Price per Unit Actual], 'Date Table'[Year Offset] = -1)
			VAR _alltime = CALCULATE([RP Average Price per Unit Actual], 'Date Table'[Year Offset] <= -1 )
			
			
			VAR __offset_1 = SWITCH(SELECTEDVALUE('Dim Period Comp'[Order]), 0, _monthoffset, 1, _qtdoffset, 2,_ytdoffset, 3,_fyroffset, _alltime)
			
			RETURN 
