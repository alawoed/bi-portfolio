	measure 'PP Production Volume Variance Prevs Period' = ```
			
			-- Month-over-month comparison
			VAR _monthrevA = CALCULATE([PP Production Volume Actual], 'Date Table'[Month Offset] = -2)
			VAR _monthrevB = CALCULATE([PP Production Volume Actual], 'Date Table'[Month Offset] = -1)
			VAR _monthvar = _monthrevB - _monthrevA
			VAR _monthvarper = DIVIDE(_monthvar, ABS(_monthrevA))
			
			-- Quarter-over-quarter comparison
			VAR _qtdrevA = CALCULATE([PP Production Volume Actual], 'Date Table'[Quarter Offset] = -4)
			VAR _qtdrevB = CALCULATE([PP Production Volume Actual & Forecast], 'Date Table'[Quarter Offset] = 0)
			VAR _qtdvar = _qtdrevB - _qtdrevA
			VAR _qtdvarper = DIVIDE(_qtdvar, ABS(_qtdrevA))
			
			-- Year-over-year comparison
			VAR _ytdrevA = CALCULATE([PP Production Volume Budget], 'Date Table'[Year Offset] = 0 && 'Date Table'[Month Offset] <= -1) 
			VAR _ytdrevB = CALCULATE([PP Production Volume Actual & Forecast], 'Date Table'[Year Offset] = 0 && 'Date Table'[Month Offset] <= -1)
			VAR _ytdvar = _ytdrevB - _ytdrevA
			VAR _ytdvarper = DIVIDE(_ytdvar, ABS(_ytdrevA))
			
			-- Full-year forecast comparison
			VAR _fyrrevA = CALCULATE([PP Production Volume Actual], 'Date Table'[Year Offset] = -1) 
			VAR _fyrrevB = CALCULATE([PP Production Volume Actual & Forecast], 'Date Table'[Year Offset] = 0)
			VAR _fyrvar = _fyrrevB - _fyrrevA
			VAR _fyrvarper = DIVIDE(_fyrvar, ABS(_fyrrevA))
			
			
			-- Final values based on selected comparison type
			VAR finalvar = 
			    SWITCH(
			        SELECTEDVALUE('Dim Period Comp'[Order]),
			        0, _monthvar,
			        1, _qtdvar,
			        2, _ytdvar,
			        3, _fyrvar,
			        BLANK()
			    )
			
			VAR finalvarper = 
			    SWITCH(
			        SELECTEDVALUE('Dim Period Comp'[Order]),
			        0, _monthvarper,
			        1, _qtdvarper,
			        2, _ytdvarper,
			        3, _fyrvarper,
			        BLANK()
			    )
			
			-- Format variance amount nicely
			VAR formart_variance = 
			    SWITCH(
			        TRUE(),
			        ABS(finalvar) >= 1000000000, FORMAT(finalvar / 1000000000, "#,0.0") & "B",
			        ABS(finalvar) >= 1000000, FORMAT(finalvar / 1000000, "#,0.0") & "M",
			        ABS(finalvar) >= 1000, FORMAT(finalvar / 1000, "#,0.0") & "K",
			        FORMAT(finalvar, "#,0.0")
			    )
			
			-- Build final output with directional icon
			VAR _varfinal = 
			    SWITCH(
			        TRUE(),
			        ISBLANK(finalvarper), UNICHAR(9660) & " " & formart_variance & " (--%)",
			        finalvar = 0, UNICHAR(9660) & " " & formart_variance & " (--%)",
			        finalvar > 0, UNICHAR(9650) & " +" & formart_variance & " (+" & FORMAT(finalvarper, "#0.0%") & ")",
			        finalvar < 0, UNICHAR(9660) & " " & formart_variance & " (" & FORMAT(finalvarper , "#0.0%") & ")"
			    )
			
			RETURN
			_varfinal
			
			```
		displayFolder: 0-Base Measures
		lineageTag: 78121c89-ba9d-47cd-b1a3-a81ae4700a2c

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'PP Production Volume Variance Forecast' = ```
			
			
			-- Month-over-month comparison
			VAR _monthrevA = CALCULATE([PP Production Volume Prev Forecast], 'Date Table'[Month Offset] = -1)
			VAR _monthrevB = CALCULATE([PP Production Volume Actual], 'Date Table'[Month Offset] = -1)
			VAR _monthvar = _monthrevB - _monthrevA
			VAR _monthvarper = DIVIDE(_monthvar, ABS(_monthrevA))
			
			-- Quarter-over-quarter comparison
			VAR _qtdrevA = IF( 
			    MONTH(TODAY()) IN {1, 4, 7, 10}, -- First month of each quarter
			    CALCULATE( [PP Production Volume Actual], 'Date Table'[Quarter Offset] = -2 ),
			    CALCULATE( [PP Production Volume Actual & Forecast], 'Date Table'[Quarter Offset] = -1) )
			VAR _qtdrevB = IF( 
			    MONTH(TODAY()) IN {1, 4, 7, 10}, -- First month of each quarter
			    CALCULATE( [PP Production Volume Actual], 'Date Table'[Quarter Offset] = -1 ),
			    CALCULATE( [PP Production Volume Actual & Forecast], 'Date Table'[Quarter Offset] = 0) )   
			VAR _qtdvar = _qtdrevB - _qtdrevA
			VAR _qtdvarper = DIVIDE(_qtdvar, ABS(_qtdrevA))
			
			-- Year-over-year comparison
			VAR _ytdrevA = CALCULATE([PP Production Volume Actual], 'Date Table'[Year Offset] = -1 && 'Date Table'[Month Offset] < -12 )
			VAR _ytdrevB = CALCULATE([PP Production Volume Actual], 'Date Table'[Year Offset] = 0 && 'Date Table'[Month Offset] <= 0)
			VAR _ytdvar = _ytdrevB - _ytdrevA
			VAR _ytdvarper = DIVIDE(_ytdvar, ABS(_ytdrevA))
			
			-- Full-year forecast comparison
			VAR _fyrrevA = CALCULATE([PP Production Volume Prev Forecast], 'Date Table'[Year Offset] = 0) 
			VAR _fyrrevB = CALCULATE([PP Production Volume Actual & Forecast], 'Date Table'[Year Offset] = 0)
			VAR _fyrvar = _fyrrevB - _fyrrevA
			VAR _fyrvarper = DIVIDE(_fyrvar, ABS(_fyrrevA))
			
			
			-- Final values based on selected comparison type
			VAR finalvar = 
			    SWITCH(
			        SELECTEDVALUE('Dim Period Comp'[Order]),
			        0, _monthvar,
			        1, _qtdvar,
			        2, _ytdvar,
			        3, _fyrvar,
			        BLANK()
			    )
			
			VAR finalvarper = 
			    SWITCH(
			        SELECTEDVALUE('Dim Period Comp'[Order]),
			        0, _monthvarper,
			        1, _qtdvarper,
			        2, _ytdvarper,
			        3, _fyrvarper,
			        BLANK()
			    )
			
			-- Format variance amount nicely
			VAR formart_variance = FORMAT(finalvar, "#,#0.0")
			
			-- Build final output with directional icon
			VAR _varfinal = 
			    SWITCH(
			        TRUE(),
			        ISBLANK(finalvarper), UNICHAR(9660) & " " & formart_variance & " (--%)",
			        finalvar = 0, UNICHAR(9660) & " " & formart_variance & " (--%)",
			        finalvar > 0, UNICHAR(9650) & " +" & formart_variance & " (+" & FORMAT(finalvarper, "#0.0%") & ")",
			        finalvar < 0, UNICHAR(9660) & " " & formart_variance & " (" & FORMAT(finalvarper , "#0.0%") & ")"
			    )
			
			RETURN
			SWITCH(
			    SELECTEDVALUE('Dim Period Comp'[Period]),
			    "All Time", "", _varfinal)
			
			```
		displayFolder: 0-Base Measures
		lineageTag: 4500a0d2-f609-463e-a65d-64a012ee09bc

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'PP Production Volume Variance Forecast Format' = ```
			
			
			-- Month-over-month comparison
			VAR _monthrevA = CALCULATE([PP Production Volume Prev Forecast], 'Date Table'[Month Offset] = -1)
			VAR _monthrevB = CALCULATE([PP Production Volume Actual], 'Date Table'[Month Offset] = -1)
			VAR _monthvar = _monthrevB - _monthrevA
			VAR _monthvarper = DIVIDE(_monthvar, ABS(_monthrevA))
			
			-- Quarter-over-quarter comparison
			VAR _qtdrevA = IF( 
			    MONTH(TODAY()) IN {1, 4, 7, 10}, -- First month of each quarter
			    CALCULATE( [PP Production Volume Actual], 'Date Table'[Quarter Offset] = -2 ),
			    CALCULATE( [PP Production Volume Actual & Forecast], 'Date Table'[Quarter Offset] = -1) )
			VAR _qtdrevB = IF( 
			    MONTH(TODAY()) IN {1, 4, 7, 10}, -- First month of each quarter
			    CALCULATE( [PP Production Volume Actual], 'Date Table'[Quarter Offset] = -1 ),
			    CALCULATE( [PP Production Volume Actual & Forecast], 'Date Table'[Quarter Offset] = -0) )   
			VAR _qtdvar = _qtdrevB - _qtdrevA
			VAR _qtdvarper = DIVIDE(_qtdvar, ABS(_qtdrevA))
			
			-- Year-over-year comparison
			VAR _ytdrevA = CALCULATE([PP Production Volume Actual], 'Date Table'[Year Offset] = -1 && 'Date Table'[Month Offset] < -12 )
			VAR _ytdrevB = CALCULATE([PP Production Volume Actual], 'Date Table'[Year Offset] = 0 && 'Date Table'[Month Offset] <= 0)
			VAR _ytdvar = _ytdrevB - _ytdrevA
			VAR _ytdvarper = DIVIDE(_ytdvar, ABS(_ytdrevA))
			
			-- Full-year forecast comparison
			VAR _fyrrevA = CALCULATE([PP Production Volume Prev Forecast], 'Date Table'[Year Offset] = 0) 
			VAR _fyrrevB = CALCULATE([PP Production Volume Actual & Forecast], 'Date Table'[Year Offset] = 0)
			VAR _fyrvar = _fyrrevB - _fyrrevA
			VAR _fyrvarper = DIVIDE(_fyrvar, ABS(_fyrrevA))
			
			
			-- Final output based on selected comparison type
			VAR _final = BLANK()
			
			VAR finalvarper = 
			    SWITCH(
			        SELECTEDVALUE('Dim Period Comp'[Order]),
			        0, _monthvar,
			        1, _qtdvar,
			        2, _ytdvar,
			        3, _fyrvar,
			        BLANK()
			    )
			
			VAR _varfinal = SWITCH(
			    TRUE(),
			    finalvarper = BLANK(), "Red",
			    finalvarper > 0, "Green",
			    finalvarper <= 0, "Red")
			
			RETURN
			_varfinal
			
			```
