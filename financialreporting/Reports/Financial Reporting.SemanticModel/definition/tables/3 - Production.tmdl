	measure 'PP Subtitle' =
			
			VAR _product = SELECTEDVALUE('Production by Product'[UOM])
			VAR _site = SELECTEDVALUE('Production by Site'[UOM])
			VAR _final = IF(SELECTEDVALUE('Switch Table'[Order]) = 0 , _site, _product )
			
			
			RETURN
			IF([PP Hier SBU Filter] = 1, COALESCE(_final, "lbs(m) - Millions of Lbs"), "lbs(m) - Millions of Lbs")
