	measure 'OR CY Budget' = ```
			//CALCULATE([Operating Rate 10k Budget], 'Date Table'[Year Offset] = 0)
			
			VAR _monthoffset = CALCULATE([Operating Rate 10k Budget], 'Date Table'[Year Offset] = 0)
