table '3 - Production'
	lineageTag: abac11ae-89cd-46b1-9ee7-b15aba7a03c6

	measure 'PP Production Volume' = ```
			
			VAR _orgvalprd = SUM('Production by Product'[Value_O])/1000000
			VAR _newvalprd = SUM('Production by Product'[Value])
			VAR _orgvalst  = SUM('Production by Site'[Value_O])/1000000
			VAR _newvalst  = SUM('Production by Site'[Value])
			
			VAR _product = SWITCH([PP Hier SBU Filter], 0 , _orgvalprd , 1 , _newvalprd)
			VAR _site = SWITCH([PP Hier SBU Filter], 0 , _orgvalst , 1 , _orgvalst)
			
			VAR _UOMp =  SELECTEDVALUE('Production by Product'[UOM])
			VAR _UOMs = SELECTEDVALUE('Production by Site'[UOM])
			VAR _pval = IF(_UOMp = "Ktons - Thousand of Tons", _newvalprd, _orgvalprd )
			VAR _sval = IF(_UOMs = "Ktons - Thousand of Tons", _newvalst, _orgvalst )
			
			RETURN
			IF(
			    SELECTEDVALUE('Switch Table'[Order]) = 0 , 
			    _sval, 
			    _pval )
			```
		displayFolder: 0-Base Measures
		lineageTag: 19d79dd2-f9af-4554-b2cb-f1c577bbde9c

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'PP Production Volume Actual' = ```
			
			VAR _product = CALCULATE([PP Production Volume], 
			                'Production by Product'[Period / Set of Books] = "Actual / Current Forecast"
			                    --&& 'Production by Product'[CATEGORY] = "FORECAST"
			                    && 'Production by Product'[Date] <= DATE( YEAR(MIN('Today'[Today])), MONTH(MIN('Today'[Today]))-1, 01))
			
			
			
			VAR _site = CALCULATE([PP Production Volume], 
			                'Production by Site'[Period / Set of Books] = "Actual / Current Forecast"
			                    --&& 'Production by Site'[CATEGORY] = "FORECAST"
			                    && 'Production by Site'[Date] <= DATE( YEAR(MIN('Today'[Today])), MONTH(MIN('Today'[Today]))-1, 01))
			
			RETURN 
			IF(
			    SELECTEDVALUE('Switch Table'[Order]) = 0 , 
			    _site, 
			    _product )
			```
		displayFolder: 0-Base Measures
		lineageTag: 085eecab-7d0b-4e07-bef6-e99100c374a4

