	measure 'PP Hier Level1 Filter' =
			
			VAR SBU = IF(
			    ISFILTERED('Dim Hierarchy'[SBU]) &&
			    COUNTROWS(VALUES('Dim Hierarchy'[SBU])) = 1, 1, 0)
			VAR Level1 = IF(ISFILTERED('Dim Hierarchy'[Level 1]), 2)
			VAR Level2 = IF(ISFILTERED('Dim Hierarchy'[Level 2]), 3)
			VAR Level3 = IF(ISFILTERED('Dim Hierarchy'[Level 3]), 3)
			VAR final = COALESCE(Level3, Level2, Level1, SBU)
			
			RETURN
			IF(SELECTEDVALUE(Dim_Hierachy[Parameter Order]) = final, 1, 0)
		displayFolder: 0-Base Measures
		lineageTag: f43809bb-9422-49cb-bbac-38e8eef0c490

