	column 'EPOptionsHY (groups)' =
			SWITCH(
				TRUE,
				ISBLANK('EPOptionsHY'[EPOptionsHY]),
				"(Blank)",
				'EPOptionsHY'[EPOptionsHY] IN {"CA&D",
					"PVC/VCM",
					"NACV ELIMS"},
				"0",
				'EPOptionsHY'[EPOptionsHY] IN {"Chlor-Alkali",
					"Derivatives",
					"Solid Specialties",
					"CA&D ELIMS"},
				"1",
				'EPOptionsHY'[EPOptionsHY] IN {"Ethylene",
					"PVC",
					"VCM",
					"PVC/VCM ELIMS"},
				"2",
				'EPOptionsHY'[EPOptionsHY]
			)
		dataType: int64
		isHidden
