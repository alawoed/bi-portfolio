	column 'SBU (groups)' =
			SWITCH(
				TRUE,
				ISBLANK('EBITDA Accounts'[SBU]),
				"(Blank)",
				'EBITDA Accounts'[SBU] IN {"NACV"},
				"0",
				'EBITDA Accounts'[SBU] IN {"CA&D"},
				"1",
				'EBITDA Accounts'[SBU] IN {"PVC/VCM"},
				"2",
				'EBITDA Accounts'[SBU]
			)
