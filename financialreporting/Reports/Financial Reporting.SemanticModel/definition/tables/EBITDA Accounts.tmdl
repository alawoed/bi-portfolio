table 'EBITDA Accounts'
	isHidden
	lineageTag: 2200522d-2457-4135-b769-cee409cd9b36

	measure 'EBITDA Accounts_Value' = ```
			
			VAR _monthly = CALCULATE(SUM('EBITDA Accounts'[Value]), 'EBITDA Accounts'[Period] = "Monthly")
			
			VAR _Yearly = CALCULATE(SUM('EBITDA Accounts'[Value]), 'EBITDA Accounts'[Period] = "Full Year")
			
			
			RETURN
			SWITCH(
			    SELECTEDVALUE('Dim Period Comp'[Order]), 
			    3, _Yearly, _monthly)
			```
		isHidden
		lineageTag: eb571727-4055-4e78-9576-0b537c4255d7

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'EBITDA Accounts SBU Filter' = ```
			
			VAR _hyfil = IF(
			    SELECTEDVALUE('Dim Hierarchy'[SBU]) = "CA&D" , 1 ,
			IF( SELECTEDVALUE('Dim Hierarchy'[SBU]) = "PVC/VCM", 2,
			0))
			
			VAR final = IF(_hyfil = SELECTEDVALUE('EBITDA Accounts'[SBU (groups)]) , 1 , 0 )
			
			RETURN 
			 final
			
			```
		formatString: 0
		isHidden
		lineageTag: 1bfce01c-9daa-41bf-8d87-eccdf2164d62

		changedProperty = IsHidden

	measure 'EBITDA Account UOM' = ```
			SELECTEDVALUE('EBITDA Accounts'[UOM]) & " - " & SELECTEDVALUE('EBITDA Accounts'[Comparison])  
			```
		isHidden
		lineageTag: 8e48b60a-2dbc-4eeb-a71f-c300baf9b6a2

