table 'Price Index'
	isHidden
	lineageTag: 06de7297-89e3-4fa1-b639-d634ad88b83f

	measure 'Argus Index_' =
			
			IF(
			    SELECTEDVALUE( 'Product'[Level 2] ) = "Caustic",
			    [Argus Index]/20,  --2000 pounts per ton muliplied by 100 cents per USD
			    BLANK()
			)
		isHidden
		lineageTag: df245d31-c602-4f6f-a39b-ef728a023a0f

		changedProperty = IsHidden

	measure 'Price Index' = AVERAGE( 'Price Index'[Value] )
		isHidden
