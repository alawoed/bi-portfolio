		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'CDI Index' =
			
			AVERAGEX(
			    FILTER(
			        'Price Index',
			        'Price Index'[Level 2] = "PVC"
			         && 'Price Index'[Sales Channel] = "Domestic"),
			    'Price Index'[Value]
			)
		isHidden
