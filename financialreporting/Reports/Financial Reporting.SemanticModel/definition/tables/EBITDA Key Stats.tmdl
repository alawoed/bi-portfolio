table 'EBITDA Key Stats'
	isHidden
	lineageTag: 384a79cc-2c1b-4522-9fe4-71016b6b500f

	measure 'EB Key Stats UOM' = SELECTEDVALUE('EBITDA Key Stats'[UOM])
		isHidden
		lineageTag: 9b4a0665-4d33-4720-9a0e-950881a9a8fb

		changedProperty = IsHidden

	measure 'EB Current Period' = ```
			
			VAR _ECU = CALCULATE([OR Operation Rates Latest Period] , 'Dim Hierarchy'[Level 1] = "ECU") 
			VAR _PVC = CALCULATE([OR Operation Rates Latest Period] , 'Dim Hierarchy'[Level 1] = "PVC") 
			VAR _ethSP = CALCULATE('EBITDA Table'[EBITDA Matrix Latest Period], 'EBITDA Table'[PRODUCT] = "Ethylene Spot")
			VAR _natgas = CALCULATE('EBITDA Table'[EBITDA Matrix Latest Period], 'EBITDA Table'[PRODUCT] = "Natural Gas")
			VAR _cauWAP = CALCULATE([RP CY CPP], 'Dim Hierarchy'[Level 2] = "Caustic") 
			VAR _MchlPrice = CALCULATE([RP CY CPP], 'Dim Hierarchy'[Level 2] = "Chlorine")
			VAR _nonV = CALCULATE('EBITDA Table'[EBITDA Matrix Latest Period], 'EBITDA Table'[PRODUCT] = "Non-Vinyl Chlorine")
			VAR _pvcWAP = CALCULATE([RP CY CPP], 'Dim Hierarchy'[Level 1] = "PVC")
			VAR _pvcSOethy = _pvcWAP - (_ethSP * 0.48)
			
			RETURN
			SWITCH(
			    SELECTEDVALUE('EBITDA Key Stats'[Ordinal Driv]),
			    1, FORMAT(_ECU, "0.0%"), 
			    2, FORMAT(_PVC, "0.0%"),
			    3, FORMAT(_ethSP, "0.0"),
			    4, FORMAT(_natgas, "0.0"),
			    5, FORMAT(_cauWAP, "0.0"),
			    6, FORMAT(_MchlPrice, "0.0"),
			    7, FORMAT(_nonV, "0.0"),
			    8, FORMAT(_pvcWAP, "0.0"),
			    9, FORMAT(_pvcSOethy, "0.0")
			) 
			
			```
		isHidden
		lineageTag: 49691498-02de-4298-99d1-2ef9267a2e1a

		changedProperty = IsHidden

	measure 'EB Comparitive Period' = ```
			
			VAR _ECU = CALCULATE([OR Operation Rates Prev Period] , 'Dim Hierarchy'[Level 1] = "ECU") 
			VAR _PVC = CALCULATE([OR Operation Rates Prev Period] , 'Dim Hierarchy'[Level 1] = "PVC") 
			VAR _ethSP = CALCULATE('EBITDA Table'[EBITDA Matrix Comp Prev Period], 'EBITDA Table'[PRODUCT] = "Ethylene Spot")
			VAR _natgas = CALCULATE('EBITDA Table'[EBITDA Matrix Comp Prev Period], 'EBITDA Table'[PRODUCT] = "Natural Gas")
			VAR _cauWAP = CALCULATE([EBITDA CPP], 'Dim Hierarchy'[Level 2] = "Caustic") 
			VAR _MchlPrice = CALCULATE([EBITDA CPP], 'Dim Hierarchy'[Level 2] = "Chlorine")
			VAR _nonV = CALCULATE('EBITDA Table'[EBITDA Matrix Comp Prev Period], 'EBITDA Table'[PRODUCT] = "Non-Vinyl Chlorine")
			VAR _pvcWAP = CALCULATE([EBITDA CPP], 'Dim Hierarchy'[Level 1] = "PVC")
			VAR _pvcSOethy = _pvcWAP - (_ethSP * 0.48)
			
			RETURN
			SWITCH(
			    SELECTEDVALUE('EBITDA Key Stats'[Ordinal Driv]),
			    1, FORMAT(_ECU, "0.0%"), 
			    2, FORMAT(_PVC, "0.0%"),
			    3, FORMAT(_ethSP, "0.0"),
			    4, FORMAT(_natgas, "0.0"),
			    5, FORMAT(_cauWAP, "0.0"),
			    6, FORMAT(_MchlPrice, "0.0"),
			    7, FORMAT(_nonV, "0.0"),
			    8, FORMAT(_pvcWAP, "0.0"),
			    9, FORMAT(_pvcSOethy, "0.0")
			) 
			
			```
