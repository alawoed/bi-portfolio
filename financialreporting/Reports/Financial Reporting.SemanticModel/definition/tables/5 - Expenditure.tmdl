			        'Date Table'[Year Offset] = 0)
			
			VAR _fyroffset = CALCULATE(
			        [T&D_Value_FC Actual],
			        'Date Table'[Year Offset] = 0)
			
			VAR _alltime = CALCULATE(
			        [T&D_Value_FC Actual] + [T&D_Value_FC Forecast],
			        'Date Table'[Year Offset] < 0)
			
			
			VAR __offset_1 = SWITCH(SELECTEDVALUE('Dim Period Comp'[Order]), 0, _monthoffset, 1, _monthoffset, 2,_ytdoffset, 3,_fyroffset, 4, _alltime)/1000000
			
			
			RETURN 
			   SWITCH(
			            IF(
			                HASONEFILTER('T&D'[Products]) &&
			                COUNTROWS(ALLSELECTED('T&D'[Products])) = 1,
			                1,0),
			                0 , BLANK() , 1 , __offset_1) 
