	measure 'MC Operating Rates Actual' =
			
			VAR volume_in_lbs = [Value_Volume_Actual]
			
			VAR oper_rate = [Value_Capacity10K]
			
			RETURN
			DIVIDE(
			    volume_in_lbs,
			    oper_rate,
			    BLANK()
			)
