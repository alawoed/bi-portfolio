		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Cash Cost' = ```
			
			VAR cash_cost_in_USD = CALCULATE([T&D_Value_Actual], 'T&D'[Account (groups)] = "Cash Cost")
			
			VAR volume_in_lbs = [T&D Vol Actual]
			
			VAR product = MIN( 'T&D'[Products] )
			
			RETURN
			
			IF(
			    product IN {"VCM", "PVC", "ETH"},
			    DIVIDE(
			        cash_cost_in_USD*100, -- USD to cents
			        volume_in_lbs,
			        BLANK()
			    ),
			    DIVIDE(
			        cash_cost_in_USD, 
			        volume_in_lbs/2000,  -- Lb to Ton
			        BLANK()
			    )
			)/1000000
			```
		displayFolder: 7-T&D
		lineageTag: d14cecc4-67a3-4f83-9149-13a7a50cdfef

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'T&D Cash Cost FC' = ```
			
			VAR _vol = CALCULATE([T&D Graph1 Actual], 'T&D'[Account (groups)] = "Volume")
			VAR _costst = CALCULATE([T&D Graph1 Actual], 'T&D'[Account] = "Fixed Cost")
			VAR product = MIN( 'T&D'[Products] )
			VAR _volUOM = CALCULATE(SELECTEDVALUE('T&D'[UOM]), 'T&D'[Account] = "Volume")
			VAR _costlbs = DIVIDE((_costst/1000000) * 100, _vol, BLANK())
			VAR _costtons = DIVIDE(_costst/1000, _vol, BLANK())
			
			VAR _cost = IF(_volUOM = "Ktons", _costtons, IF(_volUOM = "lbs(m)", _costlbs))
			
			
			RETURN
			   SWITCH(
			            IF(
			                HASONEFILTER('T&D'[Products]) &&
			                COUNTROWS(ALLSELECTED('T&D'[Products])) = 1,
			                1,0),
			                0 , BLANK() , 1 , _cost) 
			```
		displayFolder: 7-T&D
		lineageTag: e4cf129f-dca0-46e9-8fae-e77d5c36668d

		annotation PBI_FormatHint = {"isGeneralNumber":true}

