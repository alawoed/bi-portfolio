			VAR final = 
			IF(ISINSCOPE('Hierachy Bridge'[Products]),
			SWITCH(
			    SELECTEDVALUE('Dim Period Comp'[Period]),
			    "All Time", BLANK(),
			    __offset_1
			), 
			IF(ISINSCOPE('Hierachy Bridge'[Site]) , BLANK())
