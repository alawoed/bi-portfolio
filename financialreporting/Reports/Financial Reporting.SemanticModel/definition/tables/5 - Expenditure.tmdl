		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'MC VCC Latest Period' = ```
			
			VAR _monthoffset = CALCULATE(
			        [MC VCC Actual],
			        'Date Table'[Year Offset] = 0)
			
			VAR _qtdoffset = CALCULATE(
			         [MC VCC Actual] + [MC VCC Forecast],
			        'Date Table'[Year Offset] = 0 && 'Date Table'[Quarter Offset] = 0)
			        
			VAR _ytdoffset = CALCULATE(
			        [MC VCC Actual],
			        'Date Table'[Year Offset] = 0 && 'Date Table'[Month Offset] <= -1)
			
			VAR _fyroffset = CALCULATE(
			         [MC VCC Actual] + [MC VCC Forecast],
			        'Date Table'[Year Offset] = 0)
			
			VAR _alloffset = CALCULATE(
			         [MC VCC Actual],
			        'Date Table'[Year Offset] < 0)
			
			VAR __offset_1 = SWITCH(SELECTEDVALUE('Dim Period Comp'[Order]), 0, _monthoffset, 1, _qtdoffset, 2,_monthoffset, 3,_fyroffset, _alloffset)
			
			
			RETURN 
			
			   SWITCH([PP Hier SBU Filter], 0 , BLANK() , 1 , __offset_1) 
			```
		displayFolder: 4-MC Variable Conv. Cost
