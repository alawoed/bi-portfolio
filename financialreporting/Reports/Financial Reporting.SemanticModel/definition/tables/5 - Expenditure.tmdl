	measure 'SGA Variance' =
			
			VAR _monthrevA = [SGA Variance Vlue Switch]
			VAR _monthrevB = [SGA Latest Period]
			VAR _monthvar = _monthrevB - _monthrevA
			VAR _monthvarper = DIVIDE(_monthvar, ABS(_monthrevA))
			
			RETURN
			
			_monthvar
		formatString: \$#,0.0;(\$#,0.0);\$#,0.0
		displayFolder: 6-SG&A
		lineageTag: 1e1868af-3606-4b0f-93ec-689c537718a6

	measure 'SGA Variance Vlue Switch' =
			
			SWITCH(
			    SELECTEDVALUE('ExSlicer'[Value]),
			    "Prev Month", [SGA Previous Period],
			    "Budget", [SGA Latest Period Budget],
			    "Prev Forecast", [SGA Latest Prev Forecast],
			    "SQLY", [SGA Previous Period],
			    "Prev Quarter", [SGA Latest Prev Forecast],
			    "YTDLY", [SGA Previous Period],
			    "Prev Year", [SGA Previous Period],
			    BLANK()
			)
		displayFolder: 6-SG&A
		lineageTag: 37569854-47bb-49c0-b059-b5e8dcd77a46

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'SGA Variance %' =
			
			VAR _monthrevA = [SGA Variance Vlue Switch]
			VAR _monthrevB = [SGA Latest Period]
			VAR _monthvar = _monthrevB - _monthrevA
			VAR _monthvarper = DIVIDE(_monthvar, ABS(_monthrevA))
			
			RETURN
			
			IF(_monthrevB = 0 || _monthrevB = BLANK(), BLANK(), _monthvarper)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 6-SG&A
		lineageTag: c7896a4a-c16a-43de-847d-37de9be3b34d

