			```
		displayFolder: 0-Volume
		lineageTag: bf73c0fb-98f7-4868-a3a3-2818a8663a7b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Value_Capacity10K = ```
			
			VAR _orgval= SUM('Production by 10K'[Value_O])/1000000
			VAR _newval = SUM('Production by 10K'[Value] )
			
			VAR _product = SWITCH([PP Hier SBU Filter], 0 , _orgval , 1 , _newval)
			VAR _site = SWITCH([PP Hier SBU Filter], 0 , _newval , 1 , _newval)
			
			VAR _UOMp =  SELECTEDVALUE('Production by 10K'[UOM])
			VAR _UOMs = SELECTEDVALUE('Production by 10K'[UOM])
			VAR _pval = IF(_UOMp = "Ktons", _newval/1000, _orgval )
			VAR _sval = IF(_UOMs = "Ktons", _newval/1000, _orgval )
			
			RETURN
			IF(
			    SELECTEDVALUE('Switch Table'[Order]) = 0 , 
			    _sval, 
			    _pval )
			```
		displayFolder: 0-Volume
		lineageTag: 8038a6da-b363-4689-b6d9-263641b5ba76

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'MC CC Cost Actual' = ```
			
			VAR _monthoffset = CALCULATE(
			        [MC Cash Cost Value Actual],
			        'Date Table'[Year Offset] = 0 && 'Date Table'[Month Offset] <= -1)
			
			VAR _qtdoffset = CALCULATE(
			        [MC Cash Cost Value Actual],
			        'Date Table'[Year Offset] = 0 && 'Date Table'[Quarter Offset] < 0)
			        
			VAR _ytdoffset = CALCULATE(
			       [MC Cash Cost Value Actual],
			        'Date Table'[Year Offset] = 0 && 'Date Table'[Month Offset] <= -1)
			
			VAR _fyroffset = CALCULATE(
			        [MC Cash Cost Value Actual] + [MC Cash Cost Value Forecast],
			        'Date Table'[Year Offset] = 0)
			
			VAR _alltimeoffset = CALCULATE(
			        [MC Cash Cost Value Actual],
			        'Date Table'[Year Offset] < 0)
			
			VAR __offset_1 = SWITCH(SELECTEDVALUE('Dim Period Comp'[Order]), 0, _monthoffset, 1, _qtdoffset, 2,_ytdoffset, 3,_fyroffset, _alltimeoffset)
			
			VAR _UOM = CALCULATE(SELECTEDVALUE('Hierachy Bridge'[UOM]), 'Hierachy Bridge'[UOM] <> BLANK())
			
			VAR _final = SWITCH([PP Hier SBU Filter], 0 , BLANK() , 1 , __offset_1) 
			
			RETURN 
			
			SWITCH(
			    TRUE(),
			    _UOM = "Ton", 
			    _final, 
			    _final * 100)
			```
		displayFolder: 2-MC Cash Cost
		lineageTag: c0041892-2c27-4822-a654-c02c0d3e181c

		annotation PBI_FormatHint = {"isGeneralNumber":true}

