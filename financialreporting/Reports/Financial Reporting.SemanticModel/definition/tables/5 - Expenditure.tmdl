	measure 'CPX Latest Period Delta' =
			
			VAR _e = [CPX Latest Period Actual Matrix]
			VAR _f = [CPX Latest Period Prev F Matrix]
			VAR _cp = (_e - _f)
			
			VAR _sl = SELECTEDVALUE(ExCapex[SlicerValue])
			VAR _bt = [CPX Latest Period Budget Matrix]
			VAR _bdgt = (_e - _bt)
			
			RETURN
			IF(_sl = "Budget", _bdgt, _cp)
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: 8-CAPEX
		lineageTag: e5d9a57a-671a-4c84-8c3a-96aa3801dce2

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'CPX Latest Period Delta %' =
			
			VAR _e = [CPX Latest Period Actual Matrix]
			VAR _f = [CPX Latest Period Prev F Matrix]
			VAR _cp = DIVIDE((_e - _f), _f, 0)
			
			VAR _sl = SELECTEDVALUE(ExCapex[SlicerValue])
			VAR _bt = [CPX Latest Period Budget Matrix]
			VAR _bdgt = DIVIDE((_e - _bt), _bt, 0)
			
			RETURN
			IF(_sl = "Budget", _bdgt, _cp)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: 8-CAPEX
		lineageTag: 62d799f7-ecb4-4acd-a518-159e2337b705

