	measure 'CPX Latest Period Actual Matrix' = ```
			
			VAR _monthoffset = CALCULATE(
			        [_CPX_Value_Actual],
			        'Date Table'[Year Offset] = 0 && 'Date Table'[Month Offset] = -1)
			
			VAR _qtdoffset = CALCULATE(
			         [_CPX_Value_Actual + Forecast],
			        'Date Table'[Year Offset] = 0 && 'Date Table'[Quarter Offset] = 0)
			        
			VAR _ytdoffset = CALCULATE(
			        [_CPX_Value_Actual],
			        'Date Table'[Year Offset] = 0 && 'Date Table'[Month Offset] <= -1)
			
			VAR _fyroffset = CALCULATE(
			         [_CPX_Value_Actual + Forecast],
			        'Date Table'[Year Offset] = 0)
			
			
			VAR __offset_1 = SWITCH(SELECTEDVALUE('Dim Period Comp'[Order]), 0, _monthoffset, 1, _qtdoffset, 2,_ytdoffset, 3,_fyroffset, BLANK())
			
			
			RETURN 
			
			    __offset_1/1000000
			```
