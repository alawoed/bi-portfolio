	measure 'MC CC Cost Forecast' = ```
			
			
			VAR _monthoffset = CALCULATE(
			        [MC Cash Cost Value Forecast],
			        'Date Table'[Year Offset] = 0 )
			
			VAR _alltimeoffset = CALCULATE(
			        [MC Cash Cost Value Actual] + [MC Cash Cost Value Forecast],
			        'Date Table'[Year Offset] = 0)
			
			VAR __offset_1 = SWITCH(SELECTEDVALUE('Dim Period Comp'[Order]), 0, _monthoffset, 1, _monthoffset, 2,_monthoffset, 3,_monthoffset, _alltimeoffset)
			
			
			VAR _UOM = CALCULATE(SELECTEDVALUE('Hierachy Bridge'[UOM]), 'Hierachy Bridge'[UOM] <> BLANK())
			
			VAR _final = SWITCH([PP Hier SBU Filter], 0 , BLANK() , 1 , __offset_1) 
			
			RETURN 
			
			SWITCH(
			    TRUE(),
			    _UOM = "Ton", 
			    _final, 
			    _final * 100)
			```
		displayFolder: 2-MC Cash Cost
		lineageTag: 21b01ef9-ad85-4ed4-b451-e8f365b0e485

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'MC UOM' = ```
			
			VAR _UOM = CALCULATE(SELECTEDVALUE('Hierachy Bridge'[UOM]), 'Hierachy Bridge'[UOM] <> BLANK())
			VAR __offset_1 = SWITCH(
			                        TRUE(),
			                        _UOM = "lbs",
			                        "ct/" & _UOM,
			                        _UOM = "Ton",
			                        "$/" & _UOM)
			
			RETURN
			IF(ISINSCOPE('Hierachy Bridge'[Products]) && _UOM <> BLANK(),
			SWITCH(
			    SELECTEDVALUE('Dim Period Comp'[Period]),
			    "All Time", BLANK(),
			    __offset_1
			), 
			IF(ISINSCOPE('Hierachy Bridge'[Site]) && SELECTEDVALUE('Hierachy Bridge'[Site]) <> BLANK(), "-", BLANK())
			)
			```
		displayFolder: 1-Mft Cost
		lineageTag: cbcf41f3-af06-4274-8069-bfa3f778331d

	measure 'MC CC Latest Period' = ```
			
			VAR _monthoffset = CALCULATE(
			        [MC Cash Cost Value Actual],
			        'Date Table'[Year Offset] = 0 && 'Date Table'[Month Offset] = -1)
			
			VAR _qtdoffset = CALCULATE(
			        [MC Cash Cost Value Actual + Forecast],
			        'Date Table'[Quarter Offset] = 0)
			        
			VAR _ytdoffset = CALCULATE(
			       [MC Cash Cost Value Actual],
			        'Date Table'[Year Offset] = 0 && 'Date Table'[Month Offset] <= -1)
			
			VAR _fyroffset = CALCULATE(
			        [MC Cash Cost Value Actual + Forecast],
			        'Date Table'[Year Offset] = 0)
			
			VAR __offset_1 = SWITCH(SELECTEDVALUE('Dim Period Comp'[Order]), 0, _monthoffset, 1, _qtdoffset, 2,_ytdoffset, 3,_fyroffset, BLANK())
			
			
			VAR final = 
			IF(ISINSCOPE('Hierachy Bridge'[Products]),
			SWITCH(
			    SELECTEDVALUE('Dim Period Comp'[Period]),
			    "All Time", BLANK(),
			    __offset_1
			), 
			IF(ISINSCOPE('Hierachy Bridge'[Site]) , BLANK())
			)
			
			
			VAR nodec = FORMAT(final, "0")
			VAR dec = FORMAT(final * 100, "0.0")
			
			RETURN
			SWITCH(
			    SELECTEDVALUE('Hierachy Bridge'[UOM]),
			    "Ton", nodec, 
			    "lbs", dec)
			```
		displayFolder: 2-MC Cash Cost
		lineageTag: 670b7e89-be5b-42bc-9c83-c144a48dcba7

