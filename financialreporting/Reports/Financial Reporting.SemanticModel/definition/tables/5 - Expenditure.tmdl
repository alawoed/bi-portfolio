table '5 - Expenditure'
	lineageTag: 36603f72-7c48-4516-b5d5-c41c65d1d2ac

	measure 'MC Value' = SUM('Manufacturing Cost'[Value])/1000000
		displayFolder: 1-Mft Cost
		lineageTag: e66a4d42-786d-422a-bd53-f9fcd1aa7850

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'MC Value_Actual' = ```
			CALCULATE(
			                            [MC Value],
			                            'Manufacturing Cost'[Period Set of Books] = "Actual / Current Forecast" &&
			                            'Manufacturing Cost'[Date] <= DATE( YEAR(MIN('Today'[Today])), MONTH(MIN('Today'[Today]))-1, 01))
			
			```
		displayFolder: 1-Mft Cost
		lineageTag: 49ad966b-2d0a-40ed-9af0-9a2b385be708

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'MC Value_Forecast' =
			CALCULATE(
			                            [MC Value],
			                            'Manufacturing Cost'[Period Set of Books] = "Actual / Current Forecast" &&
			                            'Manufacturing Cost'[Date] > DATE( YEAR(MIN('Today'[Today])), MONTH(MIN('Today'[Today]))-1, 01))
		displayFolder: 1-Mft Cost
		lineageTag: 7ba151aa-49e2-4892-8d6d-dcf5baf85743

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'MC Value_Prev Forecast' =
			CALCULATE(
			                            [MC Value],
			                            'Manufacturing Cost'[Period Set of Books] = "Previous Forecast" )
		displayFolder: 1-Mft Cost
		lineageTag: 18613964-1591-4be0-8b41-84b4aaee58b4

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'MC Value_Budget' =
			CALCULATE(
			                            [MC Value],
			                            'Manufacturing Cost'[Period Set of Books] = "Budget")
		displayFolder: 1-Mft Cost
		lineageTag: 62a87e6b-1f61-418a-b499-0c4b9e0daf7f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Value_Vol = ```
			
			VAR _orgvalprd = SUM('Production by Product'[Value_O])/1000000
			VAR _newvalprd = SUM('Production by Product'[Value])
			VAR _orgvalst  = SUM('Production by Site'[Value_O])/1000000
			VAR _newvalst  = SUM('Production by Site'[Value])
			
			VAR _product = SWITCH([PP Hier SBU Filter], 0 , _orgvalprd , 1 , _newvalprd)
			VAR _site = SWITCH([PP Hier SBU Filter], 0 , _orgvalst , 1 , _orgvalst)
			
			VAR _UOMp =  SELECTEDVALUE('Production by Product'[UOM])
			VAR _UOMs = SELECTEDVALUE('Production by Site'[UOM])
			VAR _pval = IF(_UOMp = "Ktons - Thousand of Tons", _newvalprd/1000, _orgvalprd )
			VAR _sval = IF(_UOMs = "Ktons - Thousand of Tons", _newvalst/1000, _orgvalst )
			
			RETURN
			IF(
			    SELECTEDVALUE('Switch Table'[Order]) = 0 , 
			    _sval, 
			    _pval )
			
			```
		displayFolder: 0-Volume
		lineageTag: e972cf9e-7fd3-4cbe-97d9-ca80f1242d74

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Value_Volume_Actual = ```
			
			VAR _product = CALCULATE([Value_Vol], 
			                'Production by Product'[Period / Set of Books] = "Actual / Current Forecast"
			                    && 'Production by Product'[CATEGORY] = "FORECAST"
			                    && 'Production by Product'[Date] <= DATE( YEAR(MIN('Today'[Today])), MONTH(MIN('Today'[Today]))-1, 01))
			
			
			
			VAR _site = CALCULATE([Value_Vol], 
			                'Production by Site'[Period / Set of Books] = "Actual / Current Forecast"
			                    && 'Production by Site'[CATEGORY] = "FORECAST"
			                    && 'Production by Site'[Date] <= DATE( YEAR(MIN('Today'[Today])), MONTH(MIN('Today'[Today]))-1, 01))
			
			RETURN 
			IF(
			    SELECTEDVALUE('Switch Table'[Order]) = 0 , 
			    _site, 
			    _product )
			```
		displayFolder: 0-Volume
		lineageTag: a4a30812-c556-461b-bbe2-38858ddaa4b4

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Value_Volume_Budget = ```
			
			VAR _product = CALCULATE([Value_Vol], 
			                'Production by Product'[Period / Set of Books] = "Budget")
			
			
			
			VAR _site = CALCULATE([Value_Vol], 
			                'Production by Site'[Period / Set of Books] = "Budget")
			
			RETURN 
			IF(
			    SELECTEDVALUE('ExSwitch Table'[Order]) = 0 , 
			    _site, 
			    _product )
			```
		displayFolder: 0-Volume
		lineageTag: 53f5b62c-383c-415a-bb96-d31d09fc96f7

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Value_Volume_Prev Forecast' = ```
			
			VAR _product = CALCULATE([Value_Vol], 
			                'Production by Product'[Period / Set of Books] = "Previous Forecast")
			
			
			
			VAR _site = CALCULATE([Value_Vol], 
