	measure 'MC UOM sub' =
			
			
			VAR _UOM = CALCULATE(SELECTEDVALUE('Hierachy Bridge'[UOM]), 'Hierachy Bridge'[UOM] <> BLANK())
			VAR _new = IF(_UOM <> BLANK() , _UOM, "lbs")
			
			RETURN
			IF(_new = "lbs",
			"ct/" & _new & " - Cents per " & _new,
			IF(_new = "Ton",
			"$/" & _new & " - Dollars per " & _new)
			)
