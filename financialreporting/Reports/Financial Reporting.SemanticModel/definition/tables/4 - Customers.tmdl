table '4 - Customers'
	lineageTag: b4056e41-921a-4003-aaf7-06edc5e410e1

	measure 'Net Back' = ```
			
			VAR _monthoffset = CALCULATE( SUM('Customer Margin'[NetBack] ), 'Date Table'[Month Offset] = -1)
			VAR _qtdoffset = CALCULATE( SUM('Customer Margin'[NetBack] ), 'Date Table'[Year Offset] = 0 && 'Date Table'[Quarter Offset] = -1)
			VAR _ytdoffset = CALCULATE( SUM('Customer Margin'[NetBack] ), 'Date Table'[Year Offset] = 0 && 'Date Table'[Month Offset] <= -1)
			VAR _fyroffset = CALCULATE( SUM('Customer Margin'[NetBack] ), 'Date Table'[Year Offset] = 0)
			VAR _alltime = CALCULATE( SUM('Customer Margin'[NetBack] ) , 'Date Table'[Year Offset] <= 0 )
			
			
			VAR __offset_1 = SWITCH(SELECTEDVALUE('Dim Period Comp'[Order]), 0, _monthoffset, 1, _qtdoffset, 2,_ytdoffset, 3,_fyroffset, _alltime)
			
			RETURN 
			    __offset_1
			```
		displayFolder: 0-Base Measures
		lineageTag: 74f9f908-d3c5-4e10-81fb-8f2a0b3d15fe

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Net Back per Unit' = ```
			
			VAR net_back = [Net Back]
			VAR volume = IF( SELECTEDVALUE( 'Customer Margin'[Product] ) = "Caustic", [CM Volume Sold Actual for Bubble Chart] * 1000, [CM Volume Sold Actual for Bubble Chart] * 1000000 )
			VAR per_unit = 
			DIVIDE(
			    net_back,
			    volume,
			    BLANK()
			)
			RETURN
			IF( SELECTEDVALUE( 'Customer Margin'[Product] ) = "Caustic", per_unit, per_unit * 100 )
			--IF (per_unit > 10, BLANK(), per_unit ) * 100
			```
		formatString: 0.00
		displayFolder: 0-Base Measures
		lineageTag: a3de666b-717e-4457-9910-ebe7e243504a

	measure 'Net Back per Lb in USD' =
			
			//Since we are using the Convert To Millions calculation Group, we need to multiply by 1,000,000 the Net back per Lb to account for the millions division performed by the calculation group "Convert to Millions" over the whole visual
			[Net Back per Unit] * 1000000
		displayFolder: 0-Base Measures
		lineageTag: 34d2ace5-0728-4679-b160-8e4284476b32

		annotation PBI_FormatHint = {"isGeneralNumber":true}

