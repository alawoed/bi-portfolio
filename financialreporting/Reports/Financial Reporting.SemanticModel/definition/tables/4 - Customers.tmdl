			VAR _ytdoffset = CALCULATE( SUM('Customer Margin'[NetSales] ), 'Date Table'[Year Offset] = 0 && 'Date Table'[Month Offset] <= -1)
			VAR _fyroffset = CALCULATE( SUM('Customer Margin'[NetSales] ), 'Date Table'[Year Offset] = 0)
			VAR _alltime = CALCULATE( SUM('Customer Margin'[NetSales] ) , 'Date Table'[Year Offset] <= 0 )
			
			
			VAR __offset_1 = SWITCH(SELECTEDVALUE('Dim Period Comp'[Order]), 0, _monthoffset, 1, _qtdoffset, 2,_ytdoffset, 3,_fyroffset, _alltime)
			
			RETURN 
			    __offset_1
			```
		displayFolder: 0-Base Measures
