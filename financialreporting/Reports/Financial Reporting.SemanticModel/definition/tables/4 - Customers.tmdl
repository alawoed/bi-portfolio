	measure 'Volume Sold by Converted Volume' =
			
			IF(
			    SELECTEDVALUE( 'Customer Margin'[Product] ) = "Caustic",
			    SUM( 'Customer Margin'[Volume Converted] )/1000,
			    SUM( 'Customer Margin'[Volume Converted] )/1000000
			)
		displayFolder: 0-Base Measures
		lineageTag: afe124b5-8312-4142-b52b-f59271f6c7a2

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'CM CY Vol Actual' = ```
			
			VAR _monthoffset = CALCULATE([Volume Sold by Converted Volume], 'Date Table'[Year Offset] = 0)
			VAR _qtdoffset = CALCULATE([Volume Sold by Converted Volume], 'Date Table'[Year Offset] = 0 && 'Date Table'[Quarter Offset] = -1)
			VAR _ytdoffset = CALCULATE([Volume Sold by Converted Volume], 'Date Table'[Year Offset] = 0 && 'Date Table'[Month Offset] <= -1)
			VAR _fyroffset = CALCULATE([Volume Sold by Converted Volume], 'Date Table'[Year Offset] = 0)
			VAR _alltime = CALCULATE([Volume Sold by Converted Volume], 'Date Table'[Year Offset] <= 0)
			
			
			VAR __offset_1 = 
			SWITCH(
			    SELECTEDVALUE('Dim Period Comp'[Order]), 
			    0, _monthoffset, 
			    1, _qtdoffset, 
			    2, _ytdoffset, 
			    3, _fyroffset, 
			    _alltime
			)
			
			RETURN 
			    __offset_1
			```
		formatString: #,0
		displayFolder: 2-Volume
		lineageTag: 1bd9eb7e-2825-4738-a85f-d9056dcfa4fb

	measure 'CM PY Vol Actual' = ```
			
			VAR _monthoffset = CALCULATE([Volume Sold by Converted Volume], 'Date Table'[Year Offset] = -1 )
			VAR _qtdoffset = CALCULATE([Volume Sold by Converted Volume], 'Date Table'[Year Offset] = -1 && 'Date Table'[Quarter Offset] < 4)
			VAR _ytdoffset = CALCULATE([Volume Sold by Converted Volume], 'Date Table'[Year Offset] = -1 && 'Date Table'[Month Offset] <-12)
			VAR _fyroffset = CALCULATE([Volume Sold by Converted Volume], 'Date Table'[Year Offset] = -1)
			VAR _alltime = BLANK()
			
			VAR __offset_1 = SWITCH(SELECTEDVALUE('Dim Period Comp'[Order]), 0, _monthoffset, 1, _qtdoffset, 2,_ytdoffset, 3,_fyroffset, _alltime)
			
			RETURN 
			    __offset_1
			```
		formatString: #,0
		displayFolder: 2-Volume
		lineageTag: be5c3e68-b55a-4a01-bd17-0523217cc2bc

	measure 'CM Hier Filter' =
			
			VAR Level2 = IF(ISFILTERED('Customer Margin'[Sales Channel]), 1)
			VAR SBU = IF(ISFILTERED('Customer Margin'[Market Segment]), 0)
			VAR final = COALESCE(SBU, Level2, 2 )
			
			
			RETURN
			IF(SELECTEDVALUE(Customer_Page_Selector[Parameter Order]) = final, 1, 0)
		displayFolder: 0-Base Measures
		lineageTag: 9b71ef14-97eb-4300-b48b-191e8613b50f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'CM CY Net Sales Actual' = ```
			
