	measure 'Subtitle Bubble Chart' =
			
			VAR _product = IF( SELECTEDVALUE( 'Customer Margin'[Product] ) = "Caustic", "$/KTon", "ct/lb" )
			RETURN "Y-axis in " & _product & "   |   Size of bubble in $(M)" & "   -   " & [Page Period Card Title]
		displayFolder: 0-Base Measures
		lineageTag: 943d28ad-9dcc-4924-9dc7-400622b80a93

	measure 'CM Volume Sold Actual for Bubble Chart' = ```
			
			VAR _monthoffset = CALCULATE([Volume Sold by Converted Volume], 'Date Table'[Month Offset] = -1)
			VAR _qtdoffset = CALCULATE([Volume Sold by Converted Volume], 'Date Table'[Year Offset] = 0 && 'Date Table'[Quarter Offset] = -1)
			VAR _ytdoffset = CALCULATE([Volume Sold by Converted Volume], 'Date Table'[Year Offset] = 0 && 'Date Table'[Month Offset] <= -1)
			VAR _fyroffset = CALCULATE([Volume Sold by Converted Volume], 'Date Table'[Year Offset] = 0)
			VAR _alltime = CALCULATE([Volume Sold by Converted Volume], 'Date Table'[Year Offset] <= 0)
			 
			 
			VAR __offset_1 =
			SWITCH(
			    SELECTEDVALUE('Dim Period Comp'[Order]),
			    0, _monthoffset,
			    1, _qtdoffset,
			    2, _ytdoffset,
			    3, _fyroffset,
			    BLANK()
			)
			 
			RETURN
			__offset_1
			   --if( SELECTEDVALUE( 'Customer Margin'[Product] ) = "Caustic", __offset_1/1000, __offset_1/1000000 ) 
			```
		formatString: 0.0
		displayFolder: 2-Volume
		lineageTag: 1d64f8c7-109a-427f-adf8-4aa62d4ef16b

	measure 'Title Bubble Chart' = ```
			
			VAR _product = IF( SELECTEDVALUE( 'Customer Margin'[Product] ) = "Caustic" , "KTON", "LB" ) 
			RETURN
			
			SWITCH(
			    SELECTEDVALUE( 'C_Margins per Lbs'[Margins Order] ),
			    0, "NET BACK PER " & _product,
			    1, "CONTRIBUTION MARGIN PER " & _product,
			    2, "GROSS CASH MARGIN PER " & _product,
			    "NET SALES PER " & _product
			)
			```
		displayFolder: 0-Base Measures
		lineageTag: dae56610-d2c4-4e76-b360-9d35e4e58208

	measure 'Title Top Customers' = ```
			
			"TOP CUSTOMERS BY " & 
			SWITCH(
			    SELECTEDVALUE( 'C_Margins per Lbs'[Margins Order] ),
			    0, "NET BACK",
			    1, "CONTRIBUTION MARGIN",
			    2, "GROSS CASH MARGIN",
			    "NET SALES"
			)
			& " $(M)"
			```
		displayFolder: 0-Base Measures
		lineageTag: 1b1acc2d-ebd7-4728-b681-bea9878edfbf

