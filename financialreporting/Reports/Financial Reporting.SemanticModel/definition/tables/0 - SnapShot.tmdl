		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Volume Produced Latest Period Actual PS' = ```
			
			
			VAR _monthoffset = CALCULATE(
			        [Volume Produced Actual PS],
			        'Date Table'[Year Offset] = 0 && 'Date Table'[Month Offset] = -1)
			
			VAR _qtdoffset = IF( 
			    MIN( 'Date Table'[Start of Quarter] ) = DATE( YEAR( TODAY() ), MONTH( TODAY() ), 1 ),
			    CALCULATE(
			        [Volume Produced Actual + Forecast PS],
			        'Date Table'[Quarter Offset] = -1),
			    CALCULATE(
			        [Volume Produced Actual + Forecast PS],
			        'Date Table'[Quarter Offset] = 0)
			)
			
			VAR _ytdoffset = CALCULATE(
			        [Volume Produced Actual PS],
			        'Date Table'[Year Offset] = 0 && 'Date Table'[Month Offset] <= 0)
			
			VAR _fyroffset = CALCULATE(
			        [Volume Produced Actual + Forecast PS],
			        'Date Table'[Year Offset] = 0)
			
			VAR __offset_1 = SWITCH(SELECTEDVALUE('Dim Period Comp'[Order]), 0, _monthoffset, 1, _qtdoffset, 2,_ytdoffset, 3,_fyroffset, BLANK())
			
			VAR formart_variance = 
			    SWITCH(
			        TRUE(),
			        ABS(__offset_1) >= 1000000, FORMAT(__offset_1 / 1000000, "#,0") & "M",
			        --ABS(__offset_1) >= 1000, FORMAT(__offset_1 / 1000, "#,0") & "K",
			        FORMAT(__offset_1, "#,0")
			    )
			
			RETURN 
			SWITCH(
			    SELECTEDVALUE('Dim Period Comp'[Period]),
			    "All Time", "",
			    formart_variance
			)
			```
		displayFolder: 4-Volume
		lineageTag: bb333ae3-6b93-4c7e-9704-7b9dff63f375

	measure 'Volume Produced Latest Period Name PS' =
			
			VAR _offset_1 = CALCULATE(
			        [Volume Produced Actual PS],
			        'Date Table'[Month Offset] = -1
			        )
			VAR _offset_2 = CALCULATE(
			        [Volume Produced Actual PS],
			        'Date Table'[Month Offset] = -2
			        )
			VAR _month_1 = CALCULATE( MIN( 'Date Table'[Year-Month] ), 'Date Table'[Month Offset] = -1 )
			VAR _month_2 = CALCULATE( MIN( 'Date Table'[Year-Month] ), 'Date Table'[Month Offset] = -2 )
			RETURN IF(
			    ISBLANK( _offset_1 ) || _offset_1 = 0,
			    _month_2,
			    _month_1
			)
