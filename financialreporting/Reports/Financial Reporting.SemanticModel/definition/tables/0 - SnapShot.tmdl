			-- Build final output with directional icon
			VAR _varfinal = 
			    SWITCH(
			        TRUE(),
			        ISBLANK(finalvarper),  "- (--%)",
			        finalvar = 0, UNICHAR(9660) & " " & formart_variance & " (--%)",
			        finalvar > 0, UNICHAR(9650) & " +" & formart_variance & " (+" & FORMAT(finalvarper, "#.0%") & ")",
			        finalvar < 0, UNICHAR(9660) & " " & formart_variance & " (" & FORMAT(finalvarper , "#.0%") & ")"
