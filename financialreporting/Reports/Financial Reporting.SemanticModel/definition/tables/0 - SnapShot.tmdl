		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Volume Produced Forecast Millions PS' = ```
			
			--[Volume Produced Forecast PS]/1000000
			
			VAR _monthoffset = CALCULATE(
			        [Volume Produced Forecast PS],
			        'Date Table'[Year Offset] = 0 && 'Date Table'[Month Offset] > -1)
			
			VAR _qtdoffset = CALCULATE(
			        [Volume Produced Forecast PS],
			        'Date Table'[Quarter Offset] >= 0)
			        
			VAR _ytdoffset = CALCULATE(
			        [Volume Produced Forecast PS],
			        'Date Table'[Year Offset] = 0 && 'Date Table'[Month Offset] >= 0)
			
			VAR _fyroffset = CALCULATE(
			        [Volume Produced Forecast PS],
			        'Date Table'[Year Offset] >= 0)
			
			VAR __offset_1 = SWITCH(SELECTEDVALUE('Dim Period Comp'[Order]), 0, _monthoffset, 1, _qtdoffset, 2,_ytdoffset, 3,_fyroffset, [Volume Produced Forecast PS])
			
			RETURN 
			
			__offset_1 / 1000000
			```
		displayFolder: 4-Volume
		lineageTag: bb849554-c87c-4b17-a1ff-c8141b4bd30e

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Volume Produced Forecast PS' = ```
			
			VAR _product =  CALCULATE([Value_by_Product_Site_Forecast], 
			        'SnapShot by Product'[ACCOUNT] IN {"PRODUCTION"})
			
			VAR _site = CALCULATE([Value_by_Product_Site_Forecast], 
			        'SnapShot by Site'[ACCOUNT] IN {"PRODUCTION"})
			
			RETURN 
			IF(
			    SELECTEDVALUE('Switch Table'[Order]) = 0 , 
			    _site, 
			    _product )
