	measure Value_by_Product_Site_Actual = ```
			
			
			VAR _site       = CALCULATE(
			                            [Value_by_Product_Site] , 
			                            'SnapShot by Site'[CATEGORY] IN {"FORECAST"} &&
			                            'SnapShot by Site'[Period / Set of Books] = "Actual / Current Forecast" &&
			                            'SnapShot by Site'[Date] <= DATE( YEAR(MIN('Today'[Today])), MONTH(MIN('Today'[Today]))-1, 01))
			
			
			VAR _product    = CALCULATE(
			                            [Value_by_Product_Site] , 
			                            'SnapShot by Product'[CATEGORY] IN {"FORECAST"} &&
			                            'SnapShot by Product'[Period / Set of Books] = "Actual / Current Forecast" &&
			                            'SnapShot by Product'[Date] <= DATE( YEAR(MIN('Today'[Today])), MONTH(MIN('Today'[Today]))-1, 01))
			
			RETURN 
			IF(
			    SELECTEDVALUE('Switch Table'[Order]) = 0 , 
			    _site, 
			    _product )
			```
		displayFolder: 0-Base Measures
		lineageTag: 263af424-e8d6-4516-a43d-531ba6a6e44e

