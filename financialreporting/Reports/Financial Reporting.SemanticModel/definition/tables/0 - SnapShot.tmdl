	measure 'EBITDA Variance Format' = ```
			
			
			-- Month-over-month comparison
			VAR _monthrevA = CALCULATE([EBITDA Prev Forecast PS], 'Date Table'[Month Offset] = -1)
			VAR _monthrevB = CALCULATE([EBITDA Actual PS], 'Date Table'[Month Offset] = -1)
			VAR _monthvar = _monthrevB - _monthrevA
			VAR _monthvarper = DIVIDE(_monthvar, ABS(_monthrevA))
			
			-- Quarter-over-quarter comparison
			VAR _qtdrevA = IF( 
			    MONTH(TODAY()) IN {1, 4, 7, 10}, -- First month of each quarter
			    CALCULATE( [EBITDA Actual PS], 'Date Table'[Quarter Offset] = -2 ),
			    CALCULATE( [EBITDA Actual PS], 'Date Table'[Quarter Offset] = -1) )
			
			VAR _qtdrevB = IF( 
			    MONTH(TODAY()) IN {1, 4, 7, 10}, -- First month of each quarter
			    CALCULATE( [EBITDA Actual + Forecast PS], 'Date Table'[Quarter Offset] = -1 ),
			    CALCULATE( [EBITDA Actual + Forecast PS], 'Date Table'[Quarter Offset] = -0) )
			    
			VAR _qtdvar = _qtdrevB - _qtdrevA
			VAR _qtdvarper = DIVIDE( _qtdvar, ABS(_qtdrevA) )
			
			-- Year-over-year comparison
			VAR _ytdrevA = CALCULATE([EBITDA Actual PS], 'Date Table'[Year Offset] = -1 && 'Date Table'[Month Offset] < -12 )
			VAR _ytdrevB = CALCULATE([EBITDA Actual PS], 'Date Table'[Year Offset] = 0 && 'Date Table'[Month Offset] <= 0)
			VAR _ytdvar = _ytdrevB - _ytdrevA
			VAR _ytdvarper = DIVIDE(_ytdvar, ABS(_ytdrevA))
			
			-- Full-year forecast comparison
			VAR _fyrrevA = CALCULATE([EBITDA Prev Forecast PS], 'Date Table'[Year Offset] = 0) 
			VAR _fyrrevB = CALCULATE([EBITDA Actual + Forecast PS], 'Date Table'[Year Offset] = 0)
			VAR _fyrvar = _fyrrevB - _fyrrevA
			VAR _fyrvarper = DIVIDE(_fyrvar, ABS(_fyrrevA))
			
			
			-- Final output based on selected comparison type
			VAR _final = BLANK()
			
			VAR finalvarper = 
			    SWITCH(
			        SELECTEDVALUE('Dim Period Comp'[Order]),
			        0, _monthvar,
			        1, _qtdvar,
			        2, _ytdvar,
			        3, _fyrvar,
			        BLANK()
			    )
			
			
			
			VAR _varfinal = SWITCH(
			    TRUE(),
			    finalvarper = BLANK(), "Red",
			    finalvarper > 0, "Green",
			    finalvarper <= 0, "Red")
			
			RETURN
			_varfinal
			```
