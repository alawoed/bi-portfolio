	measure 'Net Revenue Variance Budget' = ```
			
			
			-- Month-over-month comparison
			VAR _monthrevA = CALCULATE([Net Revenue Budget PS], 'Date Table'[Month Offset] = -1)
			VAR _monthrevB = CALCULATE([Net Revenue Actual PS], 'Date Table'[Month Offset] = -1)
			VAR _monthvar = _monthrevB - _monthrevA
			VAR _monthvarper = DIVIDE(_monthvar, ABS(_monthrevA))
			
			-- Quarter-over-quarter comparison
			VAR _qtdrevA = IF( 
			    MONTH(TODAY()) IN {1, 4, 7, 10}, -- First month of each quarter
			    CALCULATE( [Net Revenue Budget PS], 'Date Table'[Quarter Offset] = -1 ),
			    CALCULATE( [Net Revenue Budget PS], 'Date Table'[Quarter Offset] = 0) )
			
			VAR _qtdrevB = IF( 
			    MONTH(TODAY()) IN {1, 4, 7, 10}, -- First month of each quarter
			    CALCULATE( [Net Revenue Actual PS], 'Date Table'[Quarter Offset] = -1 ),
			    CALCULATE( [Net Revenue Actual PS], 'Date Table'[Quarter Offset] = 0) )
			
			VAR _qtdvar = _qtdrevB - _qtdrevA
			VAR _qtdvarper = DIVIDE(_qtdvar, ABS(_qtdrevA))
			
			-- Year-over-year comparison
			VAR _ytdrevA = CALCULATE([Net Revenue Budget PS], 'Date Table'[Year Offset] = 0 && 'Date Table'[Month Offset] < 0)
			VAR _ytdrevB = CALCULATE([Net Revenue Actual PS], 'Date Table'[Year Offset] = 0 && 'Date Table'[Month Offset] < 0)
			VAR _ytdvar = _ytdrevB - _ytdrevA
			VAR _ytdvarper = DIVIDE(_ytdvar, ABS(_ytdrevA))
			
			-- Full-year forecast comparison
			VAR _fyrrevA = CALCULATE([Net Revenue Budget PS], 'Date Table'[Year Offset] = 0) 
			VAR _fyrrevB = CALCULATE([Net Revenue Actual + Forecast PS], 'Date Table'[Year Offset] = 0)
			VAR _fyrvar = _fyrrevB - _fyrrevA
			VAR _fyrvarper = DIVIDE(_fyrvar, ABS(_fyrrevA))
			
			
			-- Final values based on selected comparison type
			VAR finalvar = 
			    SWITCH(
			        SELECTEDVALUE('Dim Period Comp'[Order]),
			        0, _monthvar,
			        1, _qtdvar,
			        2, _ytdvar,
			        3, _fyrvar,
			        BLANK()
			    )
			
			VAR finalvarper = 
			    SWITCH(
			        SELECTEDVALUE('Dim Period Comp'[Order]),
			        0, _monthvarper,
			        1, _qtdvarper,
			        2, _ytdvarper,
			        3, _fyrvarper,
			        BLANK()
			    )
			
			-- Format variance amount nicely
			VAR formart_variance = 
			    SWITCH(
			        TRUE(),
			        ABS(finalvar) >= 1000000000, FORMAT(finalvar / 1000000000, "#,0.0") & "B",
			        ABS(finalvar) >= 1000000, FORMAT(finalvar / 1000000, "#,0.0") & "M",
			        ABS(finalvar) >= 1000, FORMAT(finalvar / 1000, "#,0.0") & "K",
			        FORMAT(finalvar, "#,0.0")
			    )
			
			-- Build final output with directional icon
			VAR _varfinal = 
			    SWITCH(
			        TRUE(),
			        ISBLANK(finalvarper), UNICHAR(9660) & " " & formart_variance & " (--%)",
			        finalvar = 0, UNICHAR(9660) & " " & formart_variance & " (--%)",
			        finalvar > 0, UNICHAR(9650) & " +" & formart_variance & " (+" & FORMAT(finalvarper, "#.0%") & ")",
			        finalvar < 0, UNICHAR(9660) & " " & formart_variance & " (" & FORMAT(finalvarper , "#.0%") & ")"
			    )
			
			RETURN
			_varfinal
			
			```
		displayFolder: 1-Net Revenue
		lineageTag: 9e23e670-fb9e-4706-83b5-16e32eb8f16e

	measure 'Net Revenue Variance Forecast' = ```
			
			
			-- Month-over-month comparison
			VAR _monthrevA = CALCULATE( [Net Revenue Prev Forecast PS], 'Date Table'[Month Offset] = -1 )
			VAR _monthrevB = CALCULATE( [Net Revenue Actual PS], 'Date Table'[Month Offset] = -1 )
			VAR _monthvar = _monthrevB - _monthrevA
			VAR _monthvarper = DIVIDE( _monthvar, ABS(_monthrevA) )
			
			-- Quarter-over-quarter comparison
			VAR _qtdrevA = IF( 
			    MONTH(TODAY()) IN {1, 4, 7, 10}, -- First month of each quarter
			    CALCULATE( [Net Revenue Actual PS], 'Date Table'[Quarter Offset] = -2 ),
			    CALCULATE( [Net Revenue Actual PS], 'Date Table'[Quarter Offset] = -1) )
			
			VAR _qtdrevB = IF( 
			    MONTH(TODAY()) IN {1, 4, 7, 10}, -- First month of each quarter
			    CALCULATE( [Net Revenue Actual + Forecast PS], 'Date Table'[Quarter Offset] = -1 ),
			    CALCULATE( [Net Revenue Actual + Forecast PS], 'Date Table'[Quarter Offset] = -0) )
			    
			VAR _qtdvar = _qtdrevB - _qtdrevA
			VAR _qtdvarper = DIVIDE( _qtdvar, ABS(_qtdrevA) )
			
			-- Year-over-year comparison
			VAR _ytdrevA = CALCULATE( [Net Revenue Actual PS], 'Date Table'[Year Offset] = -1 && 'Date Table'[Month Offset] < -12 )
			VAR _ytdrevB = CALCULATE( [Net Revenue Actual PS], 'Date Table'[Year Offset] = 0 && 'Date Table'[Month Offset] <= 0 )
			VAR _ytdvar = _ytdrevB - _ytdrevA
			VAR _ytdvarper = DIVIDE( _ytdvar, ABS(_ytdrevA) )
			
			-- Full-year forecast comparison
			VAR _fyrrevA = CALCULATE( [Net Revenue Prev Forecast PS], 'Date Table'[Year Offset] = 0 ) 
			VAR _fyrrevB = CALCULATE( [Net Revenue Actual + Forecast PS], 'Date Table'[Year Offset] = 0 )
			VAR _fyrvar = _fyrrevB - _fyrrevA
			VAR _fyrvarper = DIVIDE( _fyrvar, ABS(_fyrrevA) )
			
			
			-- Final values based on selected comparison type
			VAR finalvar = 
			    SWITCH(
			        SELECTEDVALUE( 'Dim Period Comp'[Order] ),
			        0, _monthvar,
			        1, _qtdvar,
			        2, _ytdvar,
			        3, _fyrvar,
			        BLANK()
			    )
			
			VAR finalvarper = 
			    SWITCH(
