		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Net Revenue Latest Period' = ```
			
			
			VAR _monthoffset = CALCULATE(
			        [Net Revenue Actual PS],
			        'Date Table'[Year Offset] = 0 && 'Date Table'[Month Offset] = -1 )
			
			VAR _qtdoffset = IF( 
			    MONTH(TODAY()) IN {1, 4, 7, 10}, -- First month of each quarter
			    CALCULATE(
			        [Net Revenue Actual + Forecast PS],
			        'Date Table'[Quarter Offset] = -1),
			    CALCULATE(
			        [Net Revenue Actual + Forecast PS],
			        'Date Table'[Quarter Offset] = 0) )
			        
			VAR _ytdoffset = CALCULATE(
			        [Net Revenue Actual PS],
			        'Date Table'[Year Offset] = 0 && 'Date Table'[Month Offset] < 0 )
			
			VAR _fyroffset = CALCULATE(
			        [Net Revenue Actual + Forecast PS],
			        'Date Table'[Year Offset] = 0 )
			
			VAR __offset_1 = SWITCH(SELECTEDVALUE('Dim Period Comp'[Order]), 0, _monthoffset, 1, _qtdoffset, 2,_ytdoffset, 3,_fyroffset, [Net Revenue Actual PS])
			
			VAR formart_variance = 
			    SWITCH(
			        TRUE(),
			        ABS(__offset_1) >= 1000000, FORMAT(__offset_1 / 1000000, "$#,0") & "M",
			        ABS(__offset_1) >= 1000, FORMAT(__offset_1 / 1000, "$#,0") & "K",
			        FORMAT(__offset_1, "#,0")
			    )
			
			RETURN 
			SWITCH(
			    SELECTEDVALUE('Dim Period Comp'[Period]),
			    "All Time", "",
			    formart_variance
			)
