			    FILTER(
			        'SnapShot by Product', 
			        'SnapShot by Product'[ACCOUNT] IN {"PRODUCTION"} 
			    ),   
			    [Value_by_Product_Site_Previous Forecast]
			)
			
			VAR _site = SUMX(
			    FILTER(
			        'SnapShot by Site', 
			        'SnapShot by Site'[ACCOUNT] IN {"PRODUCTION"} 
			    ),   
			    [Value_by_Product_Site_Previous Forecast]
			)
			
			RETURN 
			IF(
			    SELECTEDVALUE('Switch Table'[Order]) = 0 , 
			    _site, 
			    _product )
