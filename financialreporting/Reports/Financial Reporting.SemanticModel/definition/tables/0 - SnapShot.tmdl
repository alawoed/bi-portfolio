		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Volume Produced Variance Forecast' = ```
			
			
			-- Month-over-month comparison
			VAR _monthrevA = CALCULATE([Volume Produced Prev Forecast PS], 'Date Table'[Month Offset] = -1)
			VAR _monthrevB = CALCULATE([Volume Produced Actual PS], 'Date Table'[Month Offset] = -1)
			VAR _monthvar = _monthrevB - _monthrevA
			VAR _monthvarper = DIVIDE(_monthvar, ABS(_monthrevA))
			
			-- Quarter-over-quarter comparison
			VAR _qtdrevA = IF( 
			    MONTH(TODAY()) IN {1, 4, 7, 10}, 
			    CALCULATE( [Volume Produced Actual PS], 'Date Table'[Quarter Offset] = -2),
			    CALCULATE( [Volume Produced Actual PS], 'Date Table'[Quarter Offset] = -1) )
			VAR _qtdrevB = IF( 
			    MONTH(TODAY()) IN {1, 4, 7, 10}, 
			    CALCULATE( [Volume Produced Actual + Forecast PS], 'Date Table'[Quarter Offset] = -1 ),
			    CALCULATE( [Volume Produced Actual + Forecast PS], 'Date Table'[Quarter Offset] = 0) )
			VAR _qtdvar = _qtdrevB - _qtdrevA
			VAR _qtdvarper = DIVIDE(_qtdvar, ABS(_qtdrevA))
			
			-- Year-over-year comparison
			VAR _ytdrevA = CALCULATE([Volume Produced Actual PS], 'Date Table'[Year Offset] = -1 && 'Date Table'[Month Offset] < -12 )
			VAR _ytdrevB = CALCULATE([Volume Produced Actual PS], 'Date Table'[Year Offset] = 0 && 'Date Table'[Month Offset] <= 0)
			VAR _ytdvar = _ytdrevB - _ytdrevA
			VAR _ytdvarper = DIVIDE(_ytdvar, ABS(_ytdrevA))
			
			-- Full-year forecast comparison
			VAR _fyrrevA = CALCULATE([Volume Produced Prev Forecast PS], 'Date Table'[Year Offset] = 0) 
			VAR _fyrrevB = CALCULATE([Volume Produced Actual + Forecast PS], 'Date Table'[Year Offset] = 0)
			VAR _fyrvar = _fyrrevB - _fyrrevA
			VAR _fyrvarper = DIVIDE(_fyrvar, ABS(_fyrrevA))
			
			
			-- Final values based on selected comparison type
			VAR finalvar = 
			    SWITCH(
			        SELECTEDVALUE('Dim Period Comp'[Order]),
			        0, _monthvar,
			        1, _qtdvar,
			        2, _ytdvar,
			        3, _fyrvar,
			        BLANK()
			    )
			
			VAR finalvarper = 
			    SWITCH(
			        SELECTEDVALUE('Dim Period Comp'[Order]),
			        0, _monthvarper,
			        1, _qtdvarper,
			        2, _ytdvarper,
			        3, _fyrvarper,
			        BLANK()
			    )
			
			-- Format variance amount nicely
			VAR formart_variance = 
			    SWITCH(
			        TRUE(),
			        ABS(finalvar) >= 1000000000, FORMAT(finalvar / 1000000000, "#,0.0") & "B",
			        ABS(finalvar) >= 1000000, FORMAT(finalvar / 1000000, "#,0.0") & "M",
			        ABS(finalvar) >= 1000, FORMAT(finalvar / 1000, "#,0.0") & "K",
			        FORMAT(finalvar, "#,0.0")
			    )
			
			-- Build final output with directional icon
			VAR _varfinal = 
			    SWITCH(
			        TRUE(),
			        ISBLANK(finalvarper),"- (--%)",
			        finalvar = 0, UNICHAR(9660) & " " & formart_variance & " (--%)",
			        finalvar > 0, UNICHAR(9650) & " +" & formart_variance & " (+" & FORMAT(finalvarper, "#0.0%") & ")",
			        finalvar < 0, UNICHAR(9660) & " " & formart_variance & " (" & FORMAT(finalvarper , "#0.0%") & ")"
			    )
			
			RETURN
			SWITCH(
			    SELECTEDVALUE('Dim Period Comp'[Period]),
			    "All Time", "", _varfinal)
			
			```
		displayFolder: 4-Volume
		lineageTag: c2f7e5c9-365f-43e2-937e-bb82b71f3212

	measure 'Volume Produced Variance Format' = ```
			
			
			-- Month-over-month comparison
			VAR _monthrevA = CALCULATE([Volume Produced Prev Forecast PS], 'Date Table'[Month Offset] = -1)
			VAR _monthrevB = CALCULATE([Volume Produced Actual PS], 'Date Table'[Month Offset] = -1)
			VAR _monthvar = _monthrevB - _monthrevA
			VAR _monthvarper = DIVIDE(_monthvar, ABS(_monthrevA))
			
			-- Quarter-over-quarter comparison
			VAR _qtdrevA = IF( 
			    MONTH(TODAY()) IN {1, 4, 7, 10}, 
			    CALCULATE( [Volume Produced Actual PS], 'Date Table'[Quarter Offset] = -2),
			    CALCULATE( [Volume Produced Actual PS], 'Date Table'[Quarter Offset] = -1) )
			VAR _qtdrevB = IF( 
			    MONTH(TODAY()) IN {1, 4, 7, 10}, 
			    CALCULATE( [Volume Produced Actual + Forecast PS], 'Date Table'[Quarter Offset] = -1 ),
			    CALCULATE( [Volume Produced Actual + Forecast PS], 'Date Table'[Quarter Offset] = 0) )
			VAR _qtdvar = _qtdrevB - _qtdrevA
			VAR _qtdvarper = DIVIDE(_qtdvar, ABS(_qtdrevA))
			
			-- Year-over-year comparison
			VAR _ytdrevA = CALCULATE([Volume Produced Actual PS], 'Date Table'[Year Offset] = -1 && 'Date Table'[Month Offset] < -12 )
			VAR _ytdrevB = CALCULATE([Volume Produced Actual PS], 'Date Table'[Year Offset] = 0 && 'Date Table'[Month Offset] <= 0)
			VAR _ytdvar = _ytdrevB - _ytdrevA
			VAR _ytdvarper = DIVIDE(_ytdvar, ABS(_ytdrevA))
			
			-- Full-year forecast comparison
			VAR _fyrrevA = CALCULATE([Volume Produced Prev Forecast PS], 'Date Table'[Year Offset] = 0) 
			VAR _fyrrevB = CALCULATE([Volume Produced Actual + Forecast PS], 'Date Table'[Year Offset] = 0)
			VAR _fyrvar = _fyrrevB - _fyrrevA
			VAR _fyrvarper = DIVIDE(_fyrvar, ABS(_fyrrevA))
			
			
			
			-- Final output based on selected comparison type
			VAR _final = BLANK()
			
			VAR finalvarper = 
			    SWITCH(
			        SELECTEDVALUE('Dim Period Comp'[Order]),
			        0, _monthvar,
			        1, _qtdvar,
			        2, _ytdvar,
			        3, _fyrvar,
			        BLANK()
			    )
			
			
			
			VAR _varfinal = SWITCH(
			    TRUE(),
			    finalvarper = BLANK(), "Red",
			    finalvarper > 0, "Green",
			    finalvarper <= 0, "Red")
			
			RETURN
			_varfinal
			```
