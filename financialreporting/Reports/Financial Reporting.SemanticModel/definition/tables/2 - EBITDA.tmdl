	measure 'EBITDA Comp Revenue' = ```
			
			VAR _prvmonth = CALCULATE(
			         [RP Net Revenue Actual],
			        'Date Table'[Month Offset] = -2)
			
			VAR _currmothnfcst = CALCULATE(
			        [RP Net Revenue Prev Forecast],
			        'Date Table'[Month Offset] = -1)
			
			VAR _nxtmonthfcst = CALCULATE(
			        [RP Net Revenue Forecast],
			        'Date Table'[Month Offset] = 0)
			
			VAR _curryrfcst = CALCULATE(
			        [RP Net Revenue Prev Forecast],
			        'Date Table'[Month Offset] = -1)
			
			VAR _prevyear = CALCULATE(
			        [RP Net Revenue Actual],
			        'Date Table'[Year Offset] = -1)
			
			VAR __offset_1 = IF(SELECTEDVALUE('Dim Period Comp'[Order]) = 0 && SELECTEDVALUE('EBITDA Comp'[Comp Ordinal]) = 1, _currmothnfcst,
			                    IF(SELECTEDVALUE('Dim Period Comp'[Order]) = 0 && SELECTEDVALUE('EBITDA Comp'[Comp Ordinal]) = 3, _nxtmonthfcst,
			                        IF(SELECTEDVALUE('Dim Period Comp'[Order]) = 0 && SELECTEDVALUE('EBITDA Comp'[Comp Ordinal]) = 2, _prvmonth,
			                            IF(SELECTEDVALUE('Dim Period Comp'[Order]) = 3 && SELECTEDVALUE('EBITDA Comp'[Comp Ordinal]) = 1, _curryrfcst,
			                                IF(SELECTEDVALUE('Dim Period Comp'[Order]) = 3 && SELECTEDVALUE('EBITDA Comp'[Comp Ordinal]) = 4, _prevyear,BLANK())
			                    ))))
			
			
			RETURN 
			    __offset_1/1000000
			```
