	measure 'EBITDA Lastest Period' = ```
			
			VAR _monthoffset = CALCULATE(
			        [EBITDA FP Actual + Forecast],
			         'Date Table'[Month Offset] = -1)
			
			VAR _qtdoffset = CALCULATE(
			        [EBITDA FP Actual + Forecast],
			        'Date Table'[Quarter Offset] = -1)
			        
			VAR _ytdoffset = CALCULATE(
			        [EBITDA FP Actual + Forecast],
			        'Date Table'[Year Offset] = 0 && 'Date Table'[Month Offset] <= -1)
			
			VAR _fyroffset = CALCULATE(
			        [EBITDA FP Actual + Forecast],
			        'Date Table'[Year Offset] = 0)
			
			VAR __offset_1 = SWITCH(SELECTEDVALUE('Dim Period Comp'[Order]), 0, _monthoffset, 1, _qtdoffset, 2,_ytdoffset, 3,_fyroffset)
			
			
			RETURN 
			SWITCH(
			    SELECTEDVALUE('Dim Period Comp'[Period]),
			    "All Time", BLANK(),
			    __offset_1/1000000
			)
			```
		displayFolder: 1-EBITDA Latest Periods
		lineageTag: 117965ca-d584-4924-b741-39d540ba3e72

		annotation PBI_FormatHint = {"isGeneralNumber":true}

