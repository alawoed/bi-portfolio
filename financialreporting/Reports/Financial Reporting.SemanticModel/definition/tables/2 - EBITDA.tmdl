	measure 'EBITDA Lastest Prev Period' = ```
			
			VAR _monthoffset = CALCULATE(
			        [EBITDA FP Prev Forecast],
			         'Date Table'[Month Offset] = -1)
			
			VAR _nxtmonthoffset = CALCULATE(
			        [EBITDA FP Actual + Forecast],
			        'Date Table'[Month Offset] = 0)
			        
			VAR _prevmonthoffset = CALCULATE(
			       [EBITDA FP Actual + Forecast],
			        'Date Table'[Month Offset] = -2)
			
			VAR _fyroffset = CALCULATE(
			       [EBITDA FP Prev Forecast],
			        'Date Table'[Year Offset] = 0)
			
			VAR __offset_1 = IF(SELECTEDVALUE('Dim Period Comp'[Order]) = 0 && SELECTEDVALUE('EBITDA Comp'[Comp Ordinal]) = 1, _monthoffset,
			                    IF(SELECTEDVALUE('Dim Period Comp'[Order]) = 0 && SELECTEDVALUE('EBITDA Comp'[Comp Ordinal]) = 3, _nxtmonthoffset,
			                        IF(SELECTEDVALUE('Dim Period Comp'[Order]) = 0 && SELECTEDVALUE('EBITDA Comp'[Comp Ordinal]) = 2, _prevmonthoffset,
			                            IF(SELECTEDVALUE('Dim Period Comp'[Order]) = 3 && SELECTEDVALUE('EBITDA Comp'[Comp Ordinal]) = 1, _fyroffset, BLANK())
			                    )))
			
			
			RETURN 
			
			    __offset_1/1000000
			```
