	column 'EBOptionsPP (groups)' =
			SWITCH(
				TRUE,
				ISBLANK('EBOptionsPP'[EBOptionsPP]),
				"(Blank)",
				'EBOptionsPP'[EBOptionsPP] IN {"Forecast",
					"Year Forecast"},
				"1",
				'EBOptionsPP'[EBOptionsPP] IN {"Prev. Month"},
				"2",
				'EBOptionsPP'[EBOptionsPP] IN {"Nxt Month Forecast"},
				"3",
				'EBOptionsPP'[EBOptionsPP]
			)
		dataType: int64
